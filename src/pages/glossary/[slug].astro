---
import Layout from '../../components/layout/Layout.astro';
import { getCollection, render } from 'astro:content';
import MenuArrow from '../../components/retro/MenuArrow.astro';

export async function getStaticPaths() {
  const entries = await getCollection('glossary');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection('glossary')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((e) => e.id === entry.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;

const tocEntries = all.map((e) => ({
  id: e.id,
  title: e.data.title,
  titleEn: e.data.titleEn,
  icon: e.data.icon,
  url: `/theomonfort/glossary/${e.id}`,
}));

const colorMap: Record<string, string> = {
  magenta: '#ff2e88',
  cyan: '#00f0ff',
  amber: '#ffb000',
  green: '#9bbc0f',
};
const accent = colorMap[entry.data.color];
---

<Layout title={`${entry.data.title} — 用語の書`}>
  <script is:inline>
    // Apply present-mode class synchronously to avoid FOUC of pink scrollbars
    (function () {
      try {
        if (new URLSearchParams(location.search).get('present') === '1') {
          document.documentElement.classList.add('present-mode');
          if (document.body) document.body.classList.add('present-mode');
          else document.addEventListener('DOMContentLoaded', () => document.body.classList.add('present-mode'));
        }
      } catch {}
    })();
  </script>
  <section
    class="max-w-3xl mx-auto px-4 py-12 glossary-detail"
    data-prev={prev ? `/theomonfort/glossary/${prev.id}` : ''}
    data-next={next ? `/theomonfort/glossary/${next.id}` : ''}
  >
    <a href="/theomonfort/glossary" class="font-pixel text-[10px] text-phosphor/60 hover:text-neon-magenta">◀ 用語一覧</a>

    <header class="mt-6 mb-8 pb-6 border-b-2 border-dashed" style={`border-color:${accent}`}>
      <div class="flex items-center gap-2 mb-2">
        <span class="font-pixel text-[10px]" style={`color:${accent}`}>
          NO.{String(entry.data.order).padStart(2, '0')}
        </span>
      </div>
      <h1 class="font-pixel text-base md:text-2xl mb-3 leading-tight flex items-center gap-3" style={`color:${accent}`}>
        <span class="text-[1.2em] leading-none shrink-0">{entry.data.icon}</span>
        <span>{entry.data.titleEn}</span>
      </h1>
      <p class="font-pixel-jp text-sm md:text-base text-phosphor/50 mb-3">{entry.data.title}</p>
      <p class="font-body text-base text-phosphor/90 leading-relaxed">{entry.data.summary}</p>
    </header>

    <article class="prose-akq">
      <Content />
    </article>

    {entry.data.links.length > 0 && (
      <aside class="mt-10 bg-shadow-ink/80 border-2 p-5" style={`border-color:${accent}`}>
        <h2 class="font-pixel text-xs mb-3" style={`color:${accent}`}>▮ 公式リンク</h2>
        <ul class="space-y-2">
          {entry.data.links.map((l) => (
            <li class="font-mono text-sm">
              <MenuArrow /> <a href={l.url} target="_blank" rel="noopener noreferrer" class="retro-link">{l.label}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    {entry.data.related.length > 0 && (
      <aside class="mt-6">
        <h2 class="font-pixel text-[10px] text-phosphor/60 mb-2">▮ 関連用語</h2>
        <div class="flex flex-wrap gap-2">
          {entry.data.related.map((slug) => {
            const r = all.find((e) => e.id === slug);
            if (!r) return null;
            return (
              <a
                href={`/theomonfort/glossary/${r.id}`}
                class="font-pixel-jp text-xs px-3 py-1 border border-phosphor/30 hover:border-neon-cyan hover:text-neon-cyan transition-colors"
              >
                {r.data.icon} {r.data.title}
              </a>
            );
          })}
        </div>
      </aside>
    )}

    <nav class="mt-12 grid grid-cols-2 gap-4 font-pixel text-[10px]">
      {prev ? (
        <a href={`/theomonfort/glossary/${prev.id}`} class="block p-3 border-2 border-phosphor/30 hover:border-neon-cyan hover:text-neon-cyan transition-colors">
          ◀ {prev.data.title}
        </a>
      ) : <span></span>}
      {next ? (
        <a href={`/theomonfort/glossary/${next.id}`} class="block p-3 border-2 border-phosphor/30 hover:border-neon-magenta hover:text-neon-magenta transition-colors text-right">
          {next.data.title} ▶
        </a>
      ) : <span></span>}
    </nav>

    <button
      type="button"
      id="present-toggle"
      class="present-hint font-pixel text-[10px]"
      aria-label="Toggle presentation mode"
    >
      <span class="key">P</span> プレゼンモード
    </button>

    <div class="present-overlay-hint font-pixel text-[10px]" aria-hidden="true">
      <span><span class="key">◀</span> <span class="key">▶</span> スライド</span>
      <span><span class="key">▲</span> <span class="key">▼</span> セクション</span>
      <span><span class="key">Esc</span> 終了</span>
    </div>

    <div class="slide-progress" aria-hidden="true"></div>
    <div class="slide-counter font-pixel text-[10px]" aria-hidden="true"></div>
    <div class="slide-title-tag" aria-hidden="true"></div>
    <nav class="present-toc" aria-label="プレゼン目次" data-current-id={entry.id} transition:persist="present-toc">
      {tocEntries.map((t, i) => (
        <a
          href={t.url}
          class="toc-item"
          data-id={t.id}
          data-active={t.id === entry.id ? 'true' : 'false'}
        >
          <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="toc-text">{t.icon} {t.titleEn || t.title}</span>
        </a>
      ))}
    </nav>
  </section>
</Layout>

<script>
  // ── Slide engine (split content by <h2>; cover = header + first H2 group) ──
  type Slide = HTMLElement[];
  let slides: Slide[] = [];
  let current = 0;
  let restoreFns: Array<() => void> = [];

  function buildSlides(): Slide[] {
    const section = document.querySelector<HTMLElement>('.glossary-detail');
    if (!section) return [];
    const header = section.querySelector<HTMLElement>(':scope > header');
    const article = section.querySelector<HTMLElement>(':scope > article.prose-akq');
    if (!article) return header ? [[header]] : [];

    const groups: HTMLElement[][] = [];
    let bucket: HTMLElement[] = [];
    Array.from(article.children).forEach((child) => {
      const el = child as HTMLElement;
      if (el.tagName === 'H2' && bucket.length > 0) {
        groups.push(bucket);
        bucket = [el];
      } else {
        bucket.push(el);
      }
    });
    if (bucket.length) groups.push(bucket);

    if (header && groups[0]) groups[0] = [header, ...groups[0]];
    else if (header) groups.unshift([header]);
    return groups;
  }

  function showSlide(i: number) {
    if (!slides.length) return;
    current = Math.max(0, Math.min(slides.length - 1, i));
    slides.forEach((slide, idx) => {
      const active = idx === current;
      slide.forEach((el) => {
        el.classList.toggle('akq-slide-hidden', !active);
        el.classList.toggle('akq-slide-active', active);
      });
    });
    updateChrome();
  }

  function updateChrome() {
    const counter = document.querySelector<HTMLElement>('.slide-counter');
    if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
    const prog = document.querySelector<HTMLElement>('.slide-progress');
    if (prog) {
      prog.innerHTML = '';
      for (let i = 0; i < slides.length; i++) {
        const bar = document.createElement('span');
        bar.className = 'slide-progress-bar' + (i <= current ? ' active' : '');
        prog.appendChild(bar);
      }
    }
    const tag = document.querySelector<HTMLElement>('.slide-title-tag');
    if (tag) {
      const titleEl = document.querySelector<HTMLElement>('.glossary-detail header h1');
      const titleHtml = titleEl?.innerHTML ?? '';
      tag.innerHTML = current === 0 ? '' : `<span class="tag-main">${titleHtml}</span>`;
      tag.classList.toggle('visible', current > 0);
    }
    // Update active item in left TOC (now glossary-entry-based, handled by syncToc)
  }

  // ── TOC across glossary entries ──────────────────────────────
  function syncToc() {
    const toc = document.querySelector<HTMLElement>('.present-toc');
    if (!toc) return;
    const currentId = (location.pathname.match(/\/glossary\/([^/]+)/)?.[1]) || toc.dataset.currentId || '';
    const items = Array.from(toc.querySelectorAll<HTMLElement>('.toc-item'));
    items.forEach((el) => {
      el.classList.remove('toc-hidden');
      el.classList.toggle('active', el.dataset.id === currentId);
      // Preserve present mode in target href when navigating
      if (document.body.classList.contains('present-mode')) {
        const u = new URL(el.getAttribute('href') || '', window.location.origin);
        u.searchParams.set('present', '1');
        el.setAttribute('href', u.pathname + (u.search ? u.search : ''));
      }
    });
    // Auto-scroll active item into view
    const active = toc.querySelector<HTMLElement>('.toc-item.active');
    if (active) active.scrollIntoView({ block: 'nearest' });
  }

  function enterSlideMode() {
    slides = buildSlides();
    if (!slides.length) return;

    // Tag every slide element so CSS can apply
    slides.forEach((slide) => slide.forEach((el) => el.classList.add('akq-slide-el')));
    restoreFns.push(() => {
      slides.forEach((slide) =>
        slide.forEach((el) => {
          el.classList.remove('akq-slide-el', 'akq-slide-hidden', 'akq-slide-active');
        })
      );
    });

    syncToc();

    // start at slide param or 0
    const params = new URLSearchParams(window.location.search);
    const s = parseInt(params.get('slide') || '0', 10);
    showSlide(isNaN(s) ? 0 : s);
  }

  function exitSlideMode() {
    restoreFns.forEach((fn) => fn());
    restoreFns = [];
    slides = [];
    current = 0;
  }

  // ── Presentation mode toggle ───────────────────────────────────
  function setPresent(on: boolean, opts: { keepSlide?: boolean } = {}) {
    const wasOn = document.body.classList.contains('present-mode');
    document.body.classList.toggle('present-mode', on);
    document.documentElement.classList.toggle('present-mode', on);
    const url = new URL(window.location.href);
    if (on) url.searchParams.set('present', '1');
    else { url.searchParams.delete('present'); url.searchParams.delete('slide'); }
    history.replaceState(null, '', url.pathname + (url.search || '') + url.hash);

    if (on && !wasOn) enterSlideMode();
    if (!on && wasOn) exitSlideMode();

    if (on) {
      document.querySelectorAll<SVGSVGElement>('.mermaid-wrap svg').forEach((svg) => {
        svg.removeAttribute('width');
        svg.removeAttribute('height');
        svg.style.maxWidth = 'none';
        svg.style.width = '100%';
        svg.style.height = 'auto';
      });
    }
  }

  function syncSlideUrl() {
    const url = new URL(window.location.href);
    url.searchParams.set('slide', String(current));
    history.replaceState(null, '', url.pathname + (url.search || '') + url.hash);
  }

  function initPresent() {
    const params = new URLSearchParams(window.location.search);
    setPresent(params.get('present') === '1');
    const btn = document.getElementById('present-toggle');
    if (btn && !btn.dataset.bound) {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () =>
        setPresent(!document.body.classList.contains('present-mode'))
      );
    }
  }

  function onKey(e: KeyboardEvent) {
    const t = e.target as HTMLElement | null;
    if (t && t.matches('input,textarea,select')) return;
    const section = document.querySelector<HTMLElement>('.glossary-detail');
    const present = document.body.classList.contains('present-mode');

    if (e.key === 'p' || e.key === 'P') {
      e.preventDefault();
      setPresent(!present);
      return;
    }
    if (e.key === 'Escape') {
      if (present) {
        setPresent(false);
      } else {
        navigateSmooth('/theomonfort/glossary');
      }
      return;
    }
    if (!present) return;

    if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') {
      e.preventDefault();
      if (current < slides.length - 1) {
        showSlide(current + 1);
        syncSlideUrl();
      } else {
        const nx = section?.dataset.next;
        if (nx) navigateSmooth(nx + '?present=1');
      }
      return;
    }
    if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
      e.preventDefault();
      if (current > 0) {
        showSlide(current - 1);
        syncSlideUrl();
      } else {
        const pv = section?.dataset.prev;
        if (pv) navigateSmooth(pv + `?present=1&slide=999`);
      }
      return;
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      const target = tocSibling(1);
      if (target) navigateSmooth(target);
      return;
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      const target = tocSibling(-1);
      if (target) navigateSmooth(target);
      return;
    }
  }

  function tocSibling(dir: 1 | -1): string | null {
    const toc = document.querySelector<HTMLElement>('.present-toc');
    if (!toc) return null;
    const items = Array.from(
      toc.querySelectorAll<HTMLAnchorElement>('.toc-item:not(.toc-hidden)'),
    );
    const currentId = location.pathname.match(/\/glossary\/([^/]+)/)?.[1] || '';
    const idx = items.findIndex(
      (el) => el.classList.contains('active') || el.dataset.id === currentId,
    );
    if (idx === -1) return null;
    const target = items[idx + dir];
    if (!target) return null;
    const href = target.getAttribute('href') || '';
    if (!href) return null;
    const u = new URL(href, window.location.origin);
    u.searchParams.set('present', '1');
    return u.pathname + '?' + u.searchParams.toString();
  }

  async function navigateSmooth(href: string) {
    try {
      const mod = await import('astro:transitions/client');
      await mod.navigate(href);
    } catch {
      window.location.href = href;
    }
  }

  document.addEventListener('keydown', onKey);
  document.addEventListener('astro:page-load', () => { initPresent(); syncToc(); });
  initPresent();
  syncToc();

  // ── Mermaid (loaded async, won't block keyboard) ───────────────
  async function renderMermaid() {
    try {
      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        themeVariables: {
          background: '#0a0e27',
          primaryColor: '#0a0e27',
          primaryTextColor: '#e8f4ff',
          primaryBorderColor: '#00f0ff',
          lineColor: '#00f0ff',
          secondaryColor: '#1a0a2e',
          tertiaryColor: '#05060f',
          fontFamily: 'DotGothic16, monospace',
        },
        securityLevel: 'loose',
      });
      const blocks = document.querySelectorAll(
        'pre[data-language="mermaid"], pre > code.language-mermaid'
      );
      blocks.forEach((el, i) => {
        const pre = el.tagName === 'PRE' ? (el as HTMLElement) : (el.parentElement as HTMLElement | null);
        if (!pre || pre.dataset.mermaidProcessed === '1') return;
        pre.dataset.mermaidProcessed = '1';
        const raw = pre.textContent || '';
        const wrap = document.createElement('div');
        wrap.className = 'mermaid-wrap';
        // Preserve slide-engine classes if pre was tagged
        if (pre.classList.contains('akq-slide-el')) wrap.classList.add('akq-slide-el');
        if (pre.classList.contains('akq-slide-hidden')) wrap.classList.add('akq-slide-hidden');
        if (pre.classList.contains('akq-slide-active')) wrap.classList.add('akq-slide-active');
        wrap.id = `mermaid-${Date.now()}-${i}`;
        wrap.textContent = raw;
        pre.replaceWith(wrap);
      });

      // Mermaid can't render inside display:none slides — temporarily
      // move hidden wraps offscreen, render, then restore.
      const allWraps = Array.from(document.querySelectorAll<HTMLElement>('.mermaid-wrap'));
      const restored: Array<{ el: HTMLElement; orig: string }> = [];
      allWraps.forEach((el) => {
        const cs = window.getComputedStyle(el);
        if (cs.display === 'none') {
          restored.push({ el, orig: el.getAttribute('style') || '' });
          el.setAttribute(
            'style',
            (el.getAttribute('style') || '') +
              ';display:block !important;position:absolute !important;left:-99999px !important;top:0 !important;width:1100px !important;'
          );
        }
      });
      await new Promise((r) => setTimeout(r, 30));
      try { await mermaid.run({ querySelector: '.mermaid-wrap' }); } catch (e) { console.error('[mermaid.run]', e); }
      // Strip mermaid's intrinsic width/height so CSS can scale the SVG to fill the wrap.
      document.querySelectorAll<SVGSVGElement>('.mermaid-wrap svg').forEach((svg) => {
        svg.removeAttribute('width');
        svg.removeAttribute('height');
        svg.style.maxWidth = 'none';
        svg.style.width = '100%';
        svg.style.height = 'auto';
      });
      restored.forEach(({ el, orig }) => {
        if (orig) el.setAttribute('style', orig); else el.removeAttribute('style');
      });

      // If we're in present mode, rebuild slides to capture new wrappers
      if (document.body.classList.contains('present-mode')) {
        exitSlideMode();
        enterSlideMode();
      }
    } catch (err) {
      console.error('[mermaid]', err);
    }
  }

  document.addEventListener('astro:page-load', renderMermaid);
  renderMermaid();
</script>

<style is:global>
  .prose-akq {
    color: #e8f4ff;
    font-family: 'Noto Sans JP', sans-serif;
    line-height: 1.85;
  }
  .prose-akq h2, .prose-akq h3 {
    font-family: 'DotGothic16', monospace;
    color: #00f0ff;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }
  .prose-akq h2 { font-size: 2.2em; line-height: 1.25; }
  .prose-akq h3 { color: #ff2e88; font-size: 1.4em; }
  .prose-akq p { margin: 1em 0; }
  .prose-akq strong { color: #ffb000; }
  .prose-akq code {
    background: #05060f;
    padding: 2px 6px;
    border: 1px solid #00f0ff;
    color: #9bbc0f;
    font-size: 0.9em;
  }
  .prose-akq pre {
    background: #05060f;
    border: 2px solid #00f0ff;
    padding: 1em;
    margin: 1.5em 0;
    overflow-x: auto;
    box-shadow: 4px 4px 0 #05060f, 0 0 8px rgba(0, 240, 255, 0.4);
  }
  .prose-akq pre code { border: none; padding: 0; background: none; color: #e8f4ff; }
  .prose-akq blockquote {
    border-left: 4px solid #ffb000;
    padding: 1em 1.2em;
    color: #e8f4ff;
    background: rgba(255, 176, 0, 0.07);
    margin: 1.8em 0;
    font-style: normal;
    box-shadow: 4px 4px 0 rgba(255, 176, 0, 0.15);
  }
  .prose-akq blockquote p { margin: 0; }
  .prose-akq blockquote strong { color: #ffb000; }

  /* ── Setup cards (scope comparison) ── */
  .prose-akq .setup-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2em;
    margin: 1.8em 0;
  }
  @media (min-width: 720px) {
    .prose-akq .setup-cards { grid-template-columns: 1fr 1fr; }
  }
  .prose-akq .setup-card {
    background: rgba(10, 14, 39, 0.7);
    border: 2px solid rgba(0, 240, 255, 0.45);
    padding: 1em 1.2em;
    box-shadow: 4px 4px 0 #05060f, 0 0 12px rgba(0, 240, 255, 0.15);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .prose-akq .setup-card:hover {
    transform: translate(-2px, -2px);
    border-color: #ff2e88;
  }
  .prose-akq .setup-card-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6em 0.9em;
    margin-bottom: 0.7em;
    padding-bottom: 0.7em;
    border-bottom: 1px dashed rgba(0, 240, 255, 0.25);
  }
  .prose-akq .setup-card-head code {
    font-size: 1.05em;
    color: #9bbc0f;
    background: rgba(155, 188, 15, 0.08);
    border: 1px solid rgba(155, 188, 15, 0.3);
    padding: 2px 8px;
  }
  .prose-akq .setup-card-tag {
    font-family: 'DotGothic16', sans-serif;
    font-size: 0.85em;
    letter-spacing: 0.05em;
  }
  .prose-akq .setup-card-tag.tag-cyan { color: #00f0ff; }
  .prose-akq .setup-card-tag.tag-magenta { color: #ff2e88; }
  .prose-akq .setup-card p { margin: 0; line-height: 1.6; }

  .mermaid-wrap {
    background: #05060f;
    border: 2px solid #00f0ff;
    padding: 1.5em;
    margin: 2em 0;
    text-align: center;
    overflow-x: auto;
    box-shadow: 4px 4px 0 #05060f, 0 0 12px rgba(0, 240, 255, 0.3);
  }
  .mermaid-wrap svg { max-width: 100%; height: auto; margin: 0 auto; }
  .prose-akq ul, .prose-akq ol { padding-left: 1.5em; margin: 1em 0; }
  .prose-akq li { margin: 0.4em 0; }
  .prose-akq a {
    color: #00f0ff;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .prose-akq a:hover { color: #ff2e88; }

  /* ── Presentation-mode toggle button (subtle hint) ── */
  .present-hint {
    position: fixed;
    right: 16px;
    bottom: 64px;
    padding: 8px 12px;
    background: rgba(10, 14, 39, 0.9);
    color: #00f0ff;
    border: 2px solid #00f0ff;
    cursor: pointer;
    z-index: 60;
    box-shadow: 4px 4px 0 #05060f, 0 0 8px rgba(0, 240, 255, 0.4);
    transition: transform 0.15s, color 0.15s, border-color 0.15s;
  }
  .present-hint:hover { transform: translate(-2px, -2px); color: #ff2e88; border-color: #ff2e88; }
  .present-hint .key {
    display: inline-block;
    padding: 1px 6px;
    margin-right: 6px;
    background: #00f0ff;
    color: #0a0e27;
    font-weight: bold;
  }
  .present-hint:hover .key { background: #ff2e88; }

  .present-overlay-hint {
    position: fixed;
    top: 16px;
    right: 16px;
    display: none;
    gap: 16px;
    color: #00f0ff;
    z-index: 60;
    opacity: 0.6;
  }
