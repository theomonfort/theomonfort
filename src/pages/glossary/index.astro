---
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';
import MenuArrow from '../../components/retro/MenuArrow.astro';

const entries = (await getCollection('glossary')).sort(
  (a, b) => a.data.order - b.data.order
);

const colorMap: Record<string, { border: string; text: string; glow: string }> = {
  magenta: { border: 'border-neon-magenta', text: 'text-neon-magenta', glow: 'hover:shadow-neon-magenta' },
  cyan:    { border: 'border-neon-cyan',    text: 'text-neon-cyan',    glow: 'hover:shadow-neon-cyan' },
  amber:   { border: 'border-crt-amber',    text: 'text-crt-amber',    glow: 'hover:shadow-neon-amber' },
  green:   { border: 'border-gb-green',     text: 'text-gb-green',     glow: 'hover:shadow-neon-amber' },
};
---

<Layout title="用語の書 — AI 開発 QUEST">
  <section class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-10">
      <p class="font-pixel text-[10px] text-crt-amber tracking-[0.3em] mb-2">▮ CHAPTER 1 ▮</p>
      <h1 class="font-pixel text-2xl md:text-4xl text-neon-magenta mb-3">用語の書</h1>
      <p class="font-pixel-jp text-lg text-neon-cyan">— GLOSSARY OF AI DRIVEN DEVELOPMENT —</p>
      <p class="font-body text-sm text-phosphor/80 mt-4 max-w-2xl">
        これから旅で出会う12の言霊。一つ一つが、君の装備になる。
      </p>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {entries.map((e) => {
        const c = colorMap[e.data.color];
        return (
          <li>
            <a
              href={`/glossary/${e.id}`}
              class={`block bg-shadow-ink/80 border-2 ${c.border} ${c.glow} p-5 transition-all duration-200 hover:-translate-y-1 group`}
            >
              <div class="flex items-start gap-3">
                <span class="text-3xl">{e.data.icon}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-baseline gap-2 mb-1">
                    <span class={`font-pixel text-[10px] ${c.text}`}>NO.{String(e.data.order).padStart(2, '0')}</span>
                    <span class="font-pixel text-[8px] text-phosphor/40">{e.data.titleEn}</span>
                  </div>
                  <h3 class={`font-pixel-jp text-xl ${c.text} mb-2`}>{e.data.title}</h3>
                  <p class="font-body text-sm text-phosphor/85 leading-relaxed line-clamp-3">
                    {e.data.summary}
                  </p>
                  <div class={`mt-3 font-pixel text-[10px] ${c.text} opacity-0 group-hover:opacity-100 transition-opacity`}>
                    <MenuArrow color={c.text} /> 詳細を読む
                  </div>
                </div>
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <div class="mt-12 text-center">
      <a href="/theomonfort/" class="font-pixel text-[10px] text-phosphor/60 hover:text-neon-magenta">◀ HUB に戻る</a>
    </div>
  </section>
</Layout>
