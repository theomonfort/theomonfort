---
import { getCollection } from 'astro:content';
import Layout from '../components/layout/Layout.astro';

const groups = (await getCollection('links')).sort(
  (a, b) => a.data.order - b.data.order,
);

const colorMap: Record<string, { hex: string; tw: string; bg: string }> = {
  magenta: { hex: '#ff2e88', tw: 'text-neon-magenta',  bg: 'rgba(255,46,136,0.10)' },
  cyan:    { hex: '#00f0ff', tw: 'text-neon-cyan',     bg: 'rgba(0,240,255,0.10)' },
  amber:   { hex: '#ffb000', tw: 'text-crt-amber',     bg: 'rgba(255,176,0,0.10)' },
  green:   { hex: '#9bbc0f', tw: 'text-gb-green',      bg: 'rgba(155,188,15,0.10)' },
};
---

<Layout title="リンクの泉 — AI 開発 QUEST">
  <section class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-10">
      <p class="font-pixel text-[10px] text-crt-amber tracking-[0.3em] mb-2">▮ CHAPTER 4 ▮</p>
      <h1 class="font-pixel text-2xl md:text-4xl text-neon-magenta mb-3">リンクの泉</h1>
      <p class="font-pixel-jp text-lg text-neon-cyan">— RESOURCES —</p>
      <p class="font-body text-sm text-phosphor/80 mt-4">
        旅の途中で立ち寄れる信頼できる泉たち。<span class="text-crt-amber">タイル</span>を選んで中身を見よう。
      </p>
    </header>

    <div id="tile-grid" class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-10">
      {groups.map((g, i) => {
        const c = colorMap[g.data.color];
        return (
          <button
            type="button"
            class={`link-tile group relative text-left p-4 border-2 bg-shadow-ink/70 transition-all ${c.tw}`}
            data-target={g.data.slug}
            style={`border-color: ${c.hex}`}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            <span class="absolute top-1 right-2 font-pixel text-[8px] tracking-widest opacity-50">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex items-start gap-3">
              <span class="text-3xl leading-none mt-1">{g.data.icon}</span>
              <div class="flex-1 min-w-0">
                <h2 class="font-pixel-jp text-base md:text-lg leading-tight mb-1">{g.data.title}</h2>
                <p class="font-body text-[11px] md:text-xs text-phosphor/70 leading-snug truncate-2">
                  {g.data.subtitle}
                </p>
              </div>
            </div>
            <div class="mt-3 flex items-center justify-between font-pixel text-[9px]">
              <span class="opacity-70">{g.data.items.length} LINKS</span>
              <span class="select-arrow opacity-0 transition-opacity">▶</span>
            </div>
            <span class="tile-scan pointer-events-none absolute inset-0" aria-hidden="true"></span>
          </button>
        );
      })}
    </div>

    <div id="link-panel" class="space-y-4">
      {groups.map((g, i) => {
        const c = colorMap[g.data.color];
        return (
          <article
            class={`link-panel-section ${i === 0 ? '' : 'hidden'}`}
            data-section={g.data.slug}
            style={`--accent:${c.hex}; --accent-bg:${c.bg};`}
          >
            <header class="flex items-baseline gap-3 mb-4 pb-2 border-b-2" style={`border-color:${c.hex}`}>
              <span class="text-2xl leading-none">{g.data.icon}</span>
              <h2 class={`font-pixel-jp text-xl md:text-2xl ${c.tw}`}>{g.data.title}</h2>
              <span class="font-pixel text-[9px] text-phosphor/50 ml-auto">{g.data.items.length} LINKS</span>
            </header>
            <ul class="grid sm:grid-cols-2 gap-3">
              {g.data.items.map((it) => (
                <li>
                  <a
                    href={it.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link-item block h-full p-3 border-2 border-phosphor/15 bg-shadow-ink/60 hover:bg-[color:var(--accent-bg)] hover:border-[color:var(--accent)] transition-colors group"
                  >
                    <div class="flex items-start gap-2">
                      <span class={`font-pixel text-[10px] mt-1 ${c.tw}`}>▶</span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-baseline gap-2">
                          <span class="font-pixel-jp text-sm md:text-base text-phosphor break-words">{it.label}</span>
                          <span class="font-mono text-[10px] text-phosphor/40 ml-auto shrink-0">↗</span>
                        </div>
                        <p class="font-body text-xs text-phosphor/70 mt-1 leading-snug">{it.desc}</p>
                      </div>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

    <div class="mt-16 text-center">
      <a href="/theomonfort/" class="font-pixel text-[10px] text-phosphor/60 hover:text-neon-magenta">◀ 道場に戻る</a>
    </div>
  </section>
</Layout>

<style is:global>
  .link-tile {
    box-shadow: 4px 4px 0 #05060f;
    cursor: pointer;
  }
  .link-tile:hover,
  .link-tile:focus-visible {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 #05060f, 0 0 16px currentColor;
    outline: none;
  }
  .link-tile:hover .select-arrow,
  .link-tile[aria-pressed='true'] .select-arrow {
    opacity: 1;
  }
  .link-tile[aria-pressed='true'] {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 #05060f, 0 0 24px currentColor;
  }
  .link-tile[aria-pressed='true']::before {
    content: '';
    position: absolute;
    inset: -2px;
    border: 2px dashed currentColor;
    opacity: 0.55;
    pointer-events: none;
  }

  .tile-scan {
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(255,255,255,0.03) 0 1px,
        transparent 1px 3px
      );
    opacity: 0.45;
    mix-blend-mode: overlay;
  }
  .link-tile[aria-pressed='true'] .tile-scan { opacity: 0.7; }

  .truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .link-panel-section { animation: panel-fade 220ms ease-out; }
  @keyframes panel-fade {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .link-item:hover .font-pixel-jp { color: var(--accent); }

  @media (max-width: 640px) {
    .link-tile { padding: 0.75rem; }
  }
</style>

<script is:inline>
  (() => {
    const tiles = document.querySelectorAll('.link-tile');
    const sections = document.querySelectorAll('.link-panel-section');

    const select = (slug) => {
      tiles.forEach((t) => {
        t.setAttribute('aria-pressed', t.dataset.target === slug ? 'true' : 'false');
      });
      sections.forEach((s) => {
        s.classList.toggle('hidden', s.dataset.section !== slug);
      });
      if (window.matchMedia('(max-width: 768px)').matches) {
        const active = document.querySelector(`.link-panel-section[data-section="${slug}"]`);
        if (active) {
          const top = active.getBoundingClientRect().top + window.scrollY - 16;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      }
    };

    tiles.forEach((t) => {
      t.addEventListener('click', () => select(t.dataset.target));
      t.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          select(t.dataset.target);
        }
      });
    });
  })();
</script>
