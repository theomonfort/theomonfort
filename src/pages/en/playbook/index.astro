---
import Layout from '../../../components/layout/Layout.astro';
import MenuArrow from '../../../components/retro/MenuArrow.astro';
import { accentClasses } from '../../../lib/theme';
import { categories, localizedCategory } from '../../../lib/playbook-categories';
import { localizedPath, siteCopy } from '../../../lib/i18n';
import { getPlaybookEntries, playbookEntryTitle } from '../../../lib/playbook';

const locale = 'en';
const t = siteCopy[locale];
const entries = await getPlaybookEntries(locale);

const grouped = categories.map((cat) => ({
  ...localizedCategory(cat, locale),
  items: entries.filter((e) => e.entry.data.category === cat.id),
}));
---

<Layout locale={locale} currentPath="/playbook" title={t.playbook.title}>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="font-pixel text-2xl md:text-4xl text-neon-magenta mb-3">{t.playbook.heading}</h1>
      <p class="font-pixel-jp text-lg text-neon-cyan">{t.playbook.subtitle}</p>
      <p class="font-pixel-jp text-sm text-phosphor/80 mt-4 max-w-2xl">
        {t.playbook.intro}{' '}
        Note: this is a personal learning resource and some details may be outdated — always refer to the <a href="https://docs.github.com/en/copilot" target="_blank" rel="noopener noreferrer" class="text-neon-cyan hover:text-neon-magenta underline">latest GitHub documentation ↗</a> for the source of truth.
      </p>

      <nav class="mt-8 flex flex-wrap md:flex-nowrap items-center gap-2 md:gap-3">
        {grouped.filter((g) => g.items.length > 0 && g.id !== 'introduction' && g.id !== 'administration').map((g, i, arr) => {
          const c = accentClasses[g.color];
          return (
            <>
              <a
                href={`#cat-${g.id}`}
                class={`font-pixel text-[10px] md:text-xs px-3 py-2 border-2 whitespace-nowrap ${c.border} ${c.text} hover:${c.glow} transition`}
              >
                {g.icon} {g.labelEn}
              </a>
              {i < arr.length - 1 && (
                <span class="font-pixel text-phosphor/60 text-2xl md:text-3xl">→</span>
              )}
            </>
          );
        })}
      </nav>
    </header>

    {grouped.map((g) => {
      if (g.items.length === 0) return null;
      const c = accentClasses[g.color];
      return (
        <section id={`cat-${g.id}`} class="mb-12 scroll-mt-24">
          <header class={`mb-5 pb-3 border-b-2 ${c.border}`}>
            <div class="flex items-baseline gap-3 flex-wrap">
              <span class="text-2xl">{g.icon}</span>
              <h2 class={`font-pixel text-lg md:text-xl ${c.text}`}>{g.labelEn}</h2>
              {g.labelJa !== g.labelEn && <span class="font-pixel-jp text-base text-phosphor/70">{g.labelJa}</span>}
              <span class={`font-pixel text-[10px] ${c.text} opacity-60 ml-auto`}>
                {g.items.length} {t.playbook.itemCount}
              </span>
            </div>
            {(g.avatar || g.localizedDescription) && (
              <div class="mt-3 flex items-start gap-3">
                {g.avatar && (
                  <img
                    src={g.avatar}
                    alt={g.actorLabel}
                    class={`h-12 w-12 rounded-full object-cover border-2 ${c.border} shrink-0`}
                  />
                )}
                <div class="flex-1 min-w-0">
                  {g.actorLabel && (
                    <p class={`font-pixel text-[10px] ${c.text} mb-1`}>👤 {g.actorLabel}</p>
                  )}
                  {g.localizedDescription && (
                    <p class="font-pixel-jp text-sm text-phosphor/80 leading-relaxed" set:html={g.localizedDescription}>
                    </p>
                  )}
                </div>
              </div>
            )}
          </header>

          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 auto-rows-fr">
            {g.items.map((item) => {
              const e = item.entry;
              const ec = c;
              const cardTitle = e.data.titleEn || playbookEntryTitle(item);
              const cardSubtitle = e.data.title !== cardTitle ? e.data.title : undefined;
              return (
                <li class="h-full">
                  <a
                    href={localizedPath(locale, `/playbook/${item.slug}`)}
                    data-playbook-tile
                    class={`flex h-full bg-shadow-ink/80 border-2 ${ec.border} ${ec.glow} p-5 transition-all duration-200 hover:-translate-y-1 group`}
                  >
                    <div class="flex items-start gap-3 w-full">
                      {e.data.icon && /\.(svg|png|jpg|jpeg|webp|gif)$/i.test(e.data.icon)
                        ? <img src={e.data.icon} alt="" class="h-8 w-8 object-contain shrink-0" />
                        : <span class="text-3xl">{e.data.icon}</span>}
                      <div class="flex-1 min-w-0">
                        <div class="flex items-baseline gap-2 mb-1">
                          <span class={`font-pixel text-[10px] ${ec.text}`}>NO.{String(e.data.order).padStart(2, '0')}</span>
                        </div>
                        <h3 class={`font-pixel text-sm md:text-base ${ec.text} mb-1 leading-tight`}>{cardTitle}</h3>
                        {cardSubtitle && <p class="font-pixel-jp text-xs text-phosphor/50 mb-2">{cardSubtitle}</p>}
                        {item.isFallback && <p class="font-pixel text-[9px] text-crt-amber mb-2">{t.common.translationPending}</p>}
                        <p class="font-pixel-jp text-sm text-phosphor/85 leading-relaxed line-clamp-3">
                          {e.data.summary}
                        </p>
                        <div class={`mt-3 font-pixel text-[10px] ${ec.text} opacity-0 group-hover:opacity-100 transition-opacity`}>
                          <MenuArrow color={ec.text} /> {t.playbook.readMore}
                        </div>
                      </div>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      );
    })}

    <div class="mt-12 text-center">
      <a href={localizedPath(locale, '/')} class="font-pixel text-[10px] text-phosphor/60 hover:text-neon-magenta">{t.common.backHome}</a>
    </div>
  </section>
</Layout>

<script>
  // On desktop (≥768px) — wide enough for the present-mode TOC sidebar — open
  // each playbook tile directly in presentation mode. Mobile keeps the plain
  // article view because present mode has no on-screen slide navigation.
  function upgradePlaybookTiles() {
    if (!window.matchMedia('(min-width: 768px)').matches) return;
    document.querySelectorAll<HTMLAnchorElement>('a[data-playbook-tile]').forEach((a) => {
      const href = a.getAttribute('href');
      if (!href || /[?&]present=1\b/.test(href)) return;
      a.setAttribute('href', href + (href.includes('?') ? '&' : '?') + 'present=1');
    });
  }
  upgradePlaybookTiles();
  document.addEventListener('astro:page-load', upgradePlaybookTiles);
</script>
