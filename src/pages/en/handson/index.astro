---
import { localizedPath } from '../../../lib/i18n';
import { getHandsonSteps } from '../../../lib/handson';

const locale = 'en';
const steps = await getHandsonSteps(locale);
const target = localizedPath(locale, `/handson/${steps[0]?.slug ?? 'intro'}`);
Astro.response.headers.set('Refresh', `0;url=${target}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="refresh" content={`0;url=${target}`}>
    <link rel="canonical" href={target}>
    <title>Redirecting…</title>
    <style>body{background:#0a0e27;color:#00f0ff;font-family:monospace;display:grid;place-items:center;height:100vh;margin:0;}a{color:#ff2e88}</style>
  </head>
  <body>
    <p>→ <a href={target}>Open the hands-on</a></p>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </body>
</html>
