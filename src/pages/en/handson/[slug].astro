---
import Layout from '../../../components/layout/Layout.astro';
import { render } from 'astro:content';
import HandsonTOC from '../../../components/handson/HandsonTOC.astro';
import HandsonStepNav from '../../../components/handson/HandsonStepNav.astro';
import { localizedPath, siteCopy } from '../../../lib/i18n';
import { getHandsonSteps, handsonStepTitle, handsonCategoryForSlug, handsonCategoryStyle } from '../../../lib/handson';

const locale = 'en';
const t = siteCopy[locale];

export async function getStaticPaths() {
  const steps = await getHandsonSteps('en');
  return steps.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const entry = item.entry;
const { Content } = await render(entry);

const all = await getHandsonSteps(locale);
const idx = all.findIndex((e) => e.slug === item.slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
const progress = Math.round(((idx + 1) / all.length) * 100);

const category = handsonCategoryForSlug(item.slug);
const { accent: asideAccent, mascot: asideMascot } = handsonCategoryStyle(category);
const articleStyle = `--entry-accent:#00f0ff;--aside-accent:${asideAccent};--aside-mascot:url('${asideMascot}')`;
---

<Layout locale={locale} currentPath={`/handson/${item.slug}`} title={`${handsonStepTitle(item)} — ${t.handson.heading}`}>
  <div
    class="handson-progress"
    style={`--handson-progress:${progress}%`}
    aria-hidden="true"
  ></div>

  <section
    class="handson-shell"
    data-prev={prev ? localizedPath(locale, `/handson/${prev.slug}`) : ''}
    data-next={next ? localizedPath(locale, `/handson/${next.slug}`) : ''}
    data-index={localizedPath(locale, '/handson')}
  >
    <aside class="handson-toc-wrap">
      <HandsonTOC
        steps={all}
        currentSlug={item.slug}
        locale={locale}
        tocLabel={t.handson.tocLabel}
        tocHeading={t.handson.tocHeading}
      />
    </aside>

    <main class="handson-main">
      <button
        type="button"
        class="handson-toc-toggle font-pixel text-[10px]"
        data-handson-toc-toggle
        aria-expanded="false"
      >
        ☰ {t.handson.tocLabel}
      </button>

      <header class="handson-step-header">
        <div class="flex items-baseline gap-3 flex-wrap mb-3">
          <span class="font-pixel text-[10px] text-crt-amber tracking-[0.3em]">
            ▮ {t.handson.stepLabel} {String(entry.data.order).padStart(2, '0')} / {String(all.length).padStart(2, '0')} ▮
          </span>
          {entry.data.duration != null && (
            <span class="font-pixel text-[10px] text-neon-cyan border border-neon-cyan/60 px-2 py-1">
              ⏱ {entry.data.duration}{t.handson.durationSuffix}
            </span>
          )}
        </div>
        <h1 class="font-pixel-jp text-2xl md:text-4xl text-neon-cyan leading-tight">
          {handsonStepTitle(item)}
        </h1>
        {item.isFallback && (
          <p class="mt-4 p-3 border-2 border-crt-amber/60 bg-shadow-ink/70 font-body text-sm text-crt-amber">
            {t.common.translationPending}
          </p>
        )}
      </header>

      <article class="prose-akq handson-article" data-handson-category={category} style={articleStyle}>
        <Content />
      </article>

      <HandsonStepNav
        prev={prev}
        next={next}
        locale={locale}
        prevLabel={t.handson.prev}
        nextLabel={t.handson.next}
      />
    </main>
  </section>

  <script>
    (() => {
      const toggle = document.querySelector('[data-handson-toc-toggle]') as HTMLButtonElement | null;
      const toc = document.querySelector('[data-handson-toc]') as HTMLElement | null;
      if (toggle && toc) {
        toggle.addEventListener('click', () => {
          const open = toc.classList.toggle('is-open');
          toggle.setAttribute('aria-expanded', String(open));
        });
      }

      // Open every link inside the handson article in a new tab UNLESS it's
      // an in-page anchor (#…) or another hands-on step (which should keep
      // the smooth in-section navigation). This preserves the user's
      // learning flow when they consult the playbook or external references.
      const enhanceLinks = () => {
        const links = document.querySelectorAll<HTMLAnchorElement>('.handson-article a[href]');
        links.forEach((a) => {
          const href = a.getAttribute('href') ?? '';
          if (!href || href.startsWith('#')) return;
          if (href.includes('/handson/')) return;
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        });
      };
      enhanceLinks();
      document.addEventListener('astro:page-load', enhanceLinks);
    })();
  </script>
</Layout>
