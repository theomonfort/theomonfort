  body.present-mode .slide-title-tag { display: none !important; }

  /* Subtle scrollbars in present mode (override global magenta chunky bars) */
  html.present-mode,
  body.present-mode,
  html.present-mode *,
  body.present-mode * {
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.15) transparent;
  }
  html.present-mode ::-webkit-scrollbar,
  body.present-mode ::-webkit-scrollbar { width: 6px; height: 6px; }
  html.present-mode ::-webkit-scrollbar-track,
  body.present-mode ::-webkit-scrollbar-track { background: transparent; }
  html.present-mode ::-webkit-scrollbar-thumb,
  body.present-mode ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border: none; border-radius: 3px; }
  html.present-mode ::-webkit-scrollbar-thumb:hover,
  body.present-mode ::-webkit-scrollbar-thumb:hover { background: rgba(0,240,255,0.35); }
  html.present-mode { overflow: hidden; }

  /* ── Left-side TOC sidebar (presentation mode only, md+) ── */
  .present-toc {
    display: none !important;
  }
  @media (min-width: 768px) {
    body.present-mode .present-toc {
      display: flex !important;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 300px;
      padding: 2.5rem 1rem 2rem;
      gap: 0.15rem;
      overflow-y: auto;
      background: #0a0e27;
      border-right: 1px solid rgba(255,46,136,0.2);
      z-index: 40;
      transition: transform 0.25s ease;
    }
    body.present-mode .playbook-detail {
      padding-left: 320px;
      transition: padding-left 0.25s ease, background 0.4s ease;
    }
    body.present-mode.akq-toc-hidden .present-toc {
      transform: translateX(-100%);
    }
    body.present-mode.akq-toc-hidden .playbook-detail {
      padding-left: 2.5rem;
    }
  }
  /* TOC toggle chip in the help overlay */
  .present-toc-toggle {
    display: inline-flex;
    align-items: center;
    background: transparent;
    border: 0;
    color: inherit;
    font: inherit;
    cursor: pointer;
    pointer-events: auto;
    padding: 0;
    transition: color 0.15s, transform 0.15s;
  }
  .present-toc-toggle:hover { color: #ff2e88; transform: translate(-1px, -1px); }
  .present-toc-toggle:hover .key { background: rgba(255, 46, 136, 0.15); border-color: #ff2e88; }
  .present-toc-toggle[aria-pressed="true"] .key {
    background: color-mix(in srgb, var(--entry-accent, #00f0ff) 40%, transparent);
  }
  @media (max-width: 767px) {
    .present-toc-toggle { display: none; }
  }
  .present-toc .toc-item {
    display: flex !important;
    align-items: baseline;
    gap: 0.55rem;
    width: 100%;
    padding: 0.5rem 0.6rem;
    text-align: left;
    position: relative;
    background: transparent;
    border: none;
    border-left: 2px solid transparent;
    color: #e8f4ff;
    font-family: 'DotGothic16', monospace;
    font-size: 0.9rem;
    line-height: 1.35;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .present-toc .toc-item.toc-hidden {
    display: none !important;
  }
  .present-toc .toc-item:hover {
    color: var(--cat-color, #00f0ff);
    background: color-mix(in srgb, var(--cat-color, #00f0ff) 10%, transparent);
    border-left-color: color-mix(in srgb, var(--cat-color, #00f0ff) 50%, transparent);
  }
  .present-toc .toc-item.active {
    color: var(--cat-color, #ff2e88) !important;
    border-left-color: var(--cat-color, #ff2e88);
    background: color-mix(in srgb, var(--cat-color, #ff2e88) 15%, transparent);
    font-weight: 700;
  }
  .present-toc .toc-section {
    font-family: 'DotGothic16', 'Noto Sans JP', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.85rem 0.6rem 0.35rem;
    margin-top: 0.4rem;
    border-bottom: 1px solid;
    opacity: 0.85;
  }
  .present-toc .toc-section:first-child {
    margin-top: 0;
  }
  .present-toc .toc-num {
    font-family: 'DotGothic16', 'Noto Sans JP', monospace;
    font-size: 0.78rem;
    color: var(--cat-color, #ffb000);
    flex-shrink: 0;
    min-width: 1.6rem;
  }
  .present-toc .toc-text {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .present-toc .toc-item:has(.toc-new-badge) {
    overflow: visible;
  }
  .present-toc .toc-text:has(.toc-new-badge) {
    overflow: visible;
    -webkit-line-clamp: unset;
    display: block;
    white-space: nowrap;
  }
  .present-toc .toc-title-text {
    position: relative;
  }
  .present-toc .toc-new-badge {
    position: absolute;
    left: 100%;
    bottom: 1em;
    margin-left: -0.55rem;
    font-family: 'Caveat', 'Comic Sans MS', cursive;
    font-weight: 700;
    font-size: 0.85rem;
    line-height: 1;
    color: #ffe14d;
    transform: rotate(20deg);
    text-shadow: 0 0 8px rgba(255, 209, 0, 0.55);
    pointer-events: none;
    white-space: nowrap;
  }

  /* ── Slide visibility ── */
  body.present-mode .akq-slide-el { /* no-op marker */ }
  body.present-mode .akq-slide-hidden:not(.present-toc):not(.toc-item):not(.toc-num):not(.toc-text) { display: none !important; }

  body.present-mode .akq-slide-active {
    animation: slide-in 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes slide-in {
    0%   { opacity: 0; transform: translateY(24px) scale(0.98); filter: blur(4px); }
    60%  { opacity: 1; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  }
  body.present-mode .playbook-detail {
    transition: background 0.4s ease, padding-left 0.25s ease;
  }

  /* Boost typography in slide mode */
  body.present-mode .playbook-detail header { margin-bottom: 1.5rem; }
  body.present-mode .playbook-detail header h1 { font-size: 3rem !important; }
  body.present-mode .playbook-detail header > p:nth-of-type(2) { font-size: 1.5rem !important; }
  body.present-mode .prose-akq { font-size: 1.5rem; line-height: 1.7; max-width: 72rem; width: 100%; margin: 0 auto; }
  body.present-mode .prose-akq h2 { font-size: 2.4rem; margin-top: 0.5em; margin-bottom: 0.7em; }
  body.present-mode .prose-akq h3 { font-size: 1.7rem; }
  body.present-mode .prose-akq pre,
  body.present-mode .mermaid-wrap {
    font-size: 1.05rem;
    padding: 2em;
    margin: 1.5em 0;
    width: 100% !important;
    max-width: none !important;
    max-height: 75vh;
    overflow-y: auto;
    overflow-x: auto;
  }
  body.present-mode .mermaid-wrap svg {
    max-width: none !important;
    width: auto !important;
    height: auto !important;
  }
  body.present-mode .prose-akq blockquote { font-size: 1.3rem; }

  /* ── Progress bars (top) ── */
  .slide-progress {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0;
    padding: 4px 16px;
    gap: 4px;
    z-index: 60;
    background: #05060f;
    border-bottom: 1px dashed color-mix(in srgb, var(--entry-accent, #00f0ff) 25%, transparent);
  }
  body.present-mode .slide-progress { display: flex; }
  /* ── "New" markers pinned above flagged nav-bar segments ── */
  .slide-new-marker {
    display: none;
    position: fixed;
    z-index: 61;
    flex-direction: row;
    align-items: center;
    gap: 3px;
    transform: translate(-50%, -8px) rotate(-3deg);
    pointer-events: none;
  }
  body.present-mode .slide-new-marker { display: flex; }
  .slide-new-arrow {
    width: 18px;
    height: 16px;
    filter: drop-shadow(0 0 6px rgba(255, 209, 0, 0.5));
  }
  .slide-new-text {
    font-family: 'Caveat', 'Comic Sans MS', cursive;
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1;
    color: #ffe14d;
    text-shadow: 0 0 8px rgba(255, 209, 0, 0.55);
    white-space: nowrap;
  }
  .slide-progress-bar {
    flex: 1;
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 6px 0;
    position: relative;
    appearance: none;
    -webkit-appearance: none;
  }
  .slide-progress-bar::before {
    content: '';
    display: block;
    height: 3px;
    background: color-mix(in srgb, var(--entry-accent, #00f0ff) 15%, transparent);
    transition: background 0.2s, box-shadow 0.2s;
  }
  .slide-progress-bar.active::before {
    background: var(--entry-accent, #00f0ff);
    box-shadow: 0 0 6px var(--entry-accent, #00f0ff);
  }
  .slide-progress-bar:hover::before {
    background: color-mix(in srgb, var(--entry-accent, #00f0ff) 55%, transparent);
  }
  .slide-progress-bar:focus-visible { outline: none; }
  .slide-progress-bar:focus-visible::before {
    background: var(--entry-accent, #00f0ff);
    box-shadow: 0 0 8px var(--entry-accent, #00f0ff);
  }

  /* ── Slide counter (bottom right) ── */
  .slide-counter {
    display: none;
    position: fixed;
    bottom: 16px;
    right: 16px;
    color: var(--entry-accent, #00f0ff);
    z-index: 60;
    padding: 6px 10px;
    background: rgba(10, 14, 39, 0.8);
    border: 1px solid color-mix(in srgb, var(--entry-accent, #00f0ff) 40%, transparent);
  }
  body.present-mode .slide-counter { display: block; }

  /* ── Slide title tag (top-left, shown after cover) ── */
