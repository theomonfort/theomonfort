---
import Layout from '../../components/layout/Layout.astro';
import { render } from 'astro:content';
import MenuArrow from '../../components/retro/MenuArrow.astro';
import { accentColorValues } from '../../lib/theme';
import { categories, localizedCategory } from '../../lib/playbook-categories';
import { localizedPath, siteCopy } from '../../lib/i18n';
import { getPlaybookEntries, playbookEntryKicker, playbookEntryTitle } from '../../lib/playbook';

const locale = 'ja';
const t = siteCopy[locale];

export async function getStaticPaths() {
  const entries = await getPlaybookEntries('ja');
  return entries.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const entry = item.entry;
const { Content } = await render(entry);

const all = await getPlaybookEntries(locale);
const idx = all.findIndex((e) => e.slug === item.slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;

const tocEntries = all.map((e) => ({
  id: e.slug,
  title: e.entry.data.titleEn || playbookEntryTitle(e),
  titleEn: playbookEntryKicker(e),
  icon: e.entry.data.icon,
  category: e.entry.data.category,
  url: localizedPath(locale, `/playbook/${e.slug}`),
}));

const tocGroups = categories
  .map((cat) => ({
    cat: localizedCategory(cat, locale),
    color: accentColorValues[cat.color],
    items: tocEntries.filter((t) => t.category === cat.id),
  }))
  .filter((g) => g.items.length > 0);

let _tocIdx = 0;

const category = categories.find((c) => c.id === entry.data.category);
const accentColor = category?.color ?? entry.data.color;
const accent = accentColorValues[accentColor];

// Group links by `group` field; preserve original order; treat ungrouped as "" (rendered without heading)
const linkGroups: { name: string; items: typeof entry.data.links }[] = [];
for (const link of entry.data.links) {
  const g = link.group ?? '';
  let bucket = linkGroups.find((lg) => lg.name === g);
  if (!bucket) {
    bucket = { name: g, items: [] };
    linkGroups.push(bucket);
  }
  bucket.items.push(link);
}
const hasGroups = linkGroups.some((g) => g.name !== '');
---

<Layout locale={locale} currentPath={`/playbook/${item.slug}`} title={`${playbookEntryTitle(item)} — ${t.playbook.heading}`}>
  <script is:inline>
    // Apply present-mode classes synchronously so the full article does not flash before slides initialize.
    if (new URLSearchParams(location.search).get('present') === '1') {
      document.documentElement.classList.add('present-mode');
      document.documentElement.classList.add('slide-preparing');
      document.body.classList.add('present-mode');
      document.body.classList.add('slide-preparing');
    }
  </script>
  <section
    class="max-w-5xl mx-auto px-4 py-12 playbook-detail"
    data-prev={prev ? localizedPath(locale, `/playbook/${prev.slug}`) : ''}
    data-next={next ? localizedPath(locale, `/playbook/${next.slug}`) : ''}
    data-index={localizedPath(locale, '/playbook')}
  >
    <a href={localizedPath(locale, '/playbook')} class="font-pixel text-[10px] text-phosphor/60 hover:text-neon-magenta">{t.playbook.backToList}</a>

    <header class="mt-6 mb-8 pb-6 border-b-2 border-dashed" style={`border-color:${accent}`}>
      <div class="flex items-center gap-2 mb-2">
        <span class="font-pixel text-[10px]" style={`color:${accent}`}>
          NO.{String(entry.data.order).padStart(2, '0')}
        </span>
      </div>
      <h1 class="font-pixel text-base md:text-2xl mb-3 leading-tight flex items-center gap-3" style={`color:${accent}`}>
        {entry.data.icon && /\.(svg|png|jpg|jpeg|webp|gif)$/i.test(entry.data.icon)
          ? <img src={entry.data.icon} alt="" class="h-[1.2em] w-auto shrink-0" />
          : <span class="text-[1.2em] leading-none shrink-0">{entry.data.icon}</span>}
        <span>{item.entry.data.titleEn || playbookEntryTitle(item)}</span>
      </h1>
      {item.entry.data.titleEn && item.entry.data.titleEn !== item.entry.data.title && (
        <p class="font-pixel-jp text-sm md:text-base text-phosphor/50 mb-3">{item.entry.data.title}</p>
      )}
      {item.isFallback && (
        <p class="mt-4 p-3 border-2 border-crt-amber/60 bg-shadow-ink/70 font-body text-sm text-crt-amber">
          {t.common.translationPending}
        </p>
      )}
    </header>

    <article class="prose-akq" data-category={entry.data.category} style={`--entry-accent:${accent}`}>
      <Content />
    </article>

    {entry.data.links.length > 0 && (
      <aside class="links-aside mt-10 p-2">
        <h2 class="font-pixel text-base md:text-lg mb-6" style={`color:${accent}`}>{t.playbook.officialLinks}</h2>
        {hasGroups ? (
          <div class="space-y-7">
            {linkGroups.map((g) => (
              <div>
                {g.name && (
                  <h3 class="font-pixel-jp text-base md:text-lg mb-3 pb-2 border-b border-dashed" style={`color:${accent}; border-color:${accent}66`}>
                    {g.name}
                  </h3>
                )}
                <ul class="space-y-3">
                  {g.items.map((l) => (
                    <li class="font-mono text-base md:text-lg leading-relaxed">
                      <MenuArrow /> <a href={l.url} target="_blank" rel="noopener noreferrer" class="retro-link">{l.label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ) : (
          <ul class="space-y-3">
            {entry.data.links.map((l) => (
              <li class="font-mono text-base md:text-lg leading-relaxed">
                <MenuArrow /> <a href={l.url} target="_blank" rel="noopener noreferrer" class="retro-link">{l.label}</a>
              </li>
            ))}
          </ul>
        )}
      </aside>
    )}

    {entry.data.related.length > 0 && (
      <aside class="mt-6">
        <h2 class="font-pixel text-[10px] text-phosphor/60 mb-2">{t.playbook.related}</h2>
        <div class="flex flex-wrap gap-2">
          {entry.data.related.map((slug) => {
            const r = all.find((e) => e.slug === slug);
            if (!r) return null;
            return (
              <a
                href={localizedPath(locale, `/playbook/${r.slug}`)}
                class="font-pixel-jp text-xs px-3 py-1 border border-phosphor/30 hover:border-neon-cyan hover:text-neon-cyan transition-colors"
              >
                {r.entry.data.icon && /\.(svg|png|jpg|jpeg|webp|gif)$/i.test(r.entry.data.icon)
                  ? <img src={r.entry.data.icon} alt="" class="inline h-[1em] w-auto align-middle mr-1" />
                  : <span>{r.entry.data.icon} </span>}{playbookEntryTitle(r)}
              </a>
            );
          })}
        </div>
      </aside>
    )}

    <nav class="mt-12 grid grid-cols-2 gap-4 font-pixel text-[10px]">
      {prev ? (
        <a href={localizedPath(locale, `/playbook/${prev.slug}`)} class="block p-3 border-2 border-phosphor/30 hover:border-neon-cyan hover:text-neon-cyan transition-colors">
          ◀ {playbookEntryTitle(prev)}
        </a>
      ) : <span></span>}
      {next ? (
        <a href={localizedPath(locale, `/playbook/${next.slug}`)} class="block p-3 border-2 border-phosphor/30 hover:border-neon-magenta hover:text-neon-magenta transition-colors text-right">
          {playbookEntryTitle(next)} ▶
        </a>
      ) : <span></span>}
    </nav>

    <button
      type="button"
      id="present-toggle"
      class="present-hint font-pixel text-[10px]"
      aria-label="Toggle presentation mode"
    >
      <span class="key">P</span> {t.playbook.presentationMode}
    </button>

    <div class="present-overlay-hint font-pixel text-[10px]" aria-hidden="true">
      <span><span class="key">◀</span> <span class="key">▶</span> {t.playbook.slides}</span>
      <span><span class="key">Esc</span> {t.playbook.exit}</span>
    </div>

    <div class="slide-progress" aria-hidden="true"></div>
    <div class="slide-counter font-pixel text-[10px]" aria-hidden="true"></div>
    <div class="slide-title-tag" aria-hidden="true"></div>
    <nav class="present-toc" aria-label={t.playbook.tocLabel} data-current-id={item.slug} transition:persist="present-toc">
      {tocGroups.map((g) => (
        <>
          <div class="toc-section" style={`color:${g.color}; border-color:${g.color}`}>
            {g.cat.labelEn}
          </div>
          {g.items.map((t) => {
            _tocIdx += 1;
            const num = _tocIdx;
            return (
              <a
                href={t.url}
                class="toc-item"
                data-id={t.id}
                data-active={t.id === item.slug ? 'true' : 'false'}
                style={`--cat-color:${g.color}`}
              >
                <span class="toc-num">{String(num).padStart(2, '0')}</span>
                <span class="toc-text">
                  {t.icon && /\.(svg|png|jpg|jpeg|webp|gif)$/i.test(t.icon)
                    ? <img src={t.icon} alt="" class="inline h-[1em] w-auto align-middle mr-3" />
                    : <span>{t.icon} </span>}{t.title}
                </span>
              </a>
            );
          })}
        </>
      ))}
    </nav>
  </section>
</Layout>

<script>
  // ── Slide engine (split content by <h2>; cover = header + first H2 group) ──
  type Slide = HTMLElement[];
  let slides: Slide[] = [];
  let current = 0;
  let restoreFns: Array<() => void> = [];
  let slideRefreshToken = 0;
  const SLIDE_PREPARING_CLASS = 'slide-preparing';

  function setSlidePreparing(on: boolean) {
    document.documentElement.classList.toggle(SLIDE_PREPARING_CLASS, on);
    document.body.classList.toggle(SLIDE_PREPARING_CLASS, on);
  }

  function buildSlides(): Slide[] {
    const section = document.querySelector<HTMLElement>('.playbook-detail');
    if (!section) return [];
    const header = section.querySelector<HTMLElement>(':scope > header');
    const article = section.querySelector<HTMLElement>(':scope > article.prose-akq');
    if (!article) return header ? [[header]] : [];

    const groups: HTMLElement[][] = [];
    let bucket: HTMLElement[] = [];
    Array.from(article.children).forEach((child) => {
      const el = child as HTMLElement;
      if (el.tagName === 'H2' && bucket.length > 0) {
        groups.push(bucket);
        bucket = [el];
      } else {
        bucket.push(el);
      }
    });
    if (bucket.length) groups.push(bucket);

    if (header && groups[0]) groups[0] = [header, ...groups[0]];
    else if (header) groups.unshift([header]);

    const linksAside = section.querySelector<HTMLElement>(':scope > aside.links-aside');
    if (linksAside) groups.push([linksAside]);

    return groups;
  }

  function showSlide(i: number) {
    if (!slides.length) return;
    current = Math.max(0, Math.min(slides.length - 1, i));
    slides.forEach((slide, idx) => {
      const active = idx === current;
      slide.forEach((el) => {
        el.classList.toggle('akq-slide-hidden', !active);
        el.classList.toggle('akq-slide-active', active);
      });
    });
    updateChrome();
  }

  function updateChrome() {
    const counter = document.querySelector<HTMLElement>('.slide-counter');
    if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
    const prog = document.querySelector<HTMLElement>('.slide-progress');
    if (prog) {
      prog.innerHTML = '';
      for (let i = 0; i < slides.length; i++) {
        const bar = document.createElement('span');
        bar.className = 'slide-progress-bar' + (i <= current ? ' active' : '');
        prog.appendChild(bar);
      }
    }
    const tag = document.querySelector<HTMLElement>('.slide-title-tag');
    if (tag) {
      const titleEl = document.querySelector<HTMLElement>('.playbook-detail header h1');
      const titleHtml = titleEl?.innerHTML ?? '';
      tag.innerHTML = current === 0 ? '' : `<span class="tag-main">${titleHtml}</span>`;
      tag.classList.toggle('visible', current > 0);
    }
    // Update active item in left TOC (now playbook-entry-based, handled by syncToc)
  }

  // ── TOC across playbook entries ──────────────────────────────
  function syncToc() {
    const toc = document.querySelector<HTMLElement>('.present-toc');
    if (!toc) return;
    const currentId = (location.pathname.match(/\/(?:en\/)?playbook\/([^/]+)/)?.[1]) || toc.dataset.currentId || '';
    const items = Array.from(toc.querySelectorAll<HTMLElement>('.toc-item'));
    items.forEach((el) => {
      el.classList.remove('toc-hidden');
      el.classList.toggle('active', el.dataset.id === currentId);
      // Preserve present mode in target href when navigating
      if (document.body.classList.contains('present-mode')) {
        const u = new URL(el.getAttribute('href') || '', window.location.origin);
        u.searchParams.set('present', '1');
        u.searchParams.delete('slide');
        el.setAttribute('href', u.pathname + (u.search ? u.search : ''));
      }
    });
    // Auto-scroll active item into view
    const active = toc.querySelector<HTMLElement>('.toc-item.active');
    if (active) active.scrollIntoView({ block: 'nearest' });
  }

  function enterSlideMode(startSlide?: number) {
    slides = buildSlides();
    if (!slides.length) return;

    // Tag every slide element so CSS can apply
    slides.forEach((slide) => slide.forEach((el) => el.classList.add('akq-slide-el')));
    restoreFns.push(() => {
      slides.forEach((slide) =>
        slide.forEach((el) => {
          el.classList.remove('akq-slide-el', 'akq-slide-hidden', 'akq-slide-active');
        })
      );
    });

    syncToc();

    // start at slide param or 0
    const params = new URLSearchParams(window.location.search);
    const s = startSlide ?? parseInt(params.get('slide') || '0', 10);
    showSlide(isNaN(s) ? 0 : s);
  }

  function resetChrome() {
    const counter = document.querySelector<HTMLElement>('.slide-counter');
    if (counter) counter.textContent = '';
    const prog = document.querySelector<HTMLElement>('.slide-progress');
    if (prog) prog.innerHTML = '';
    const tag = document.querySelector<HTMLElement>('.slide-title-tag');
    if (tag) {
      tag.innerHTML = '';
      tag.classList.remove('visible');
    }
  }

  function exitSlideMode() {
    restoreFns.forEach((fn) => fn());
    restoreFns = [];
    document
      .querySelectorAll<HTMLElement>('.akq-slide-el, .akq-slide-hidden, .akq-slide-active')
      .forEach((el) => {
        el.classList.remove('akq-slide-el', 'akq-slide-hidden', 'akq-slide-active');
      });
    slides = [];
    current = 0;
    resetChrome();
  }

  async function refreshSlideMode() {
    const token = ++slideRefreshToken;
    setSlidePreparing(true);
    exitSlideMode();
    if (!document.body.classList.contains('present-mode')) {
      setSlidePreparing(false);
      return;
    }
    if (!document.querySelector('.playbook-detail')) {
      setSlidePreparing(false);
      return;
    }
    await renderMermaid();
    if (token !== slideRefreshToken) return;
    if (!document.body.classList.contains('present-mode')) {
      setSlidePreparing(false);
      return;
    }
    if (!document.querySelector('.playbook-detail')) {
      setSlidePreparing(false);
      return;
    }
    enterSlideMode();
    syncSlideUrl();
    requestAnimationFrame(() => {
      if (token === slideRefreshToken) setSlidePreparing(false);
    });
  }

  // ── Presentation mode toggle ───────────────────────────────────
  function setPresent(on: boolean) {
    if (on && !document.querySelector('.playbook-detail')) return;
    const wasOn = document.body.classList.contains('present-mode');
    document.body.classList.toggle('present-mode', on);
    document.documentElement.classList.toggle('present-mode', on);
    const url = new URL(window.location.href);
    if (on) url.searchParams.set('present', '1');
    else { url.searchParams.delete('present'); url.searchParams.delete('slide'); }
    history.replaceState(null, '', url.pathname + (url.search || '') + url.hash);

    if (on) void refreshSlideMode();
    if (!on) {
      slideRefreshToken++;
      setSlidePreparing(false);
      if (wasOn || slides.length) exitSlideMode();
    }

    if (on) {
      document.querySelectorAll<SVGSVGElement>('.mermaid-wrap svg').forEach((svg) => {
        svg.removeAttribute('width');
        svg.removeAttribute('height');
        svg.style.maxWidth = 'none';
        svg.style.width = '100%';
        svg.style.height = 'auto';
      });
    }
  }

  function syncSlideUrl() {
    const url = new URL(window.location.href);
    if (current > 0) url.searchParams.set('slide', String(current));
    else url.searchParams.delete('slide');
    const nextUrl = url.pathname + (url.search || '') + url.hash;
    if (nextUrl !== window.location.pathname + window.location.search + window.location.hash) {
      history.replaceState(null, '', nextUrl);
    }
  }

  function initPresent() {
    const params = new URLSearchParams(window.location.search);
    setPresent(params.get('present') === '1');
    const btn = document.getElementById('present-toggle');
    if (btn && !btn.dataset.bound) {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () =>
        setPresent(!document.body.classList.contains('present-mode'))
      );
    }
  }

  function onKey(e: KeyboardEvent) {
    const t = e.target as HTMLElement | null;
    if (t && t.matches('input,textarea,select')) return;
    const section = document.querySelector<HTMLElement>('.playbook-detail');
    if (!section) return;
    const present = document.body.classList.contains('present-mode');

    if (e.key === 'p' || e.key === 'P') {
      e.preventDefault();
      setPresent(!present);
      return;
    }
    if (e.key === 'Escape') {
      if (present) {
        setPresent(false);
      } else {
        const index = section.dataset.index || '/playbook';
        navigateSmooth(index);
      }
      return;
    }
    if (!present) return;

    if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') {
      e.preventDefault();
      if (current < slides.length - 1) {
        showSlide(current + 1);
        syncSlideUrl();
      } else {
        const nx = section?.dataset.next;
        if (nx) navigateSmooth(nx + '?present=1');
      }
      return;
    }
    if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
      e.preventDefault();
      if (current > 0) {
        showSlide(current - 1);
        syncSlideUrl();
      } else {
        const pv = section?.dataset.prev;
        if (pv) navigateSmooth(pv + `?present=1&slide=999`);
      }
      return;
    }
  }

  async function navigateSmooth(href: string) {
    try {
      if (document.body.classList.contains('present-mode')) setSlidePreparing(true);
      const mod = await import('astro:transitions/client');
      await mod.navigate(href);
    } catch {
      window.location.href = href;
    }
  }

  const win = window as Window & typeof globalThis & {
    __akqGlossaryCleanup?: () => void;
  };

  win.__akqGlossaryCleanup?.();

  async function initGlossaryInteractions() {
    if (!document.querySelector('.playbook-detail')) {
      setPresent(false);
      return;
    }

    initPresent();
    if (!document.body.classList.contains('present-mode')) {
      await renderMermaid();
    }
    syncToc();
  }

  document.addEventListener('keydown', onKey);
  function preparePresentNavigation(event?: Event) {
    const currentPresent = document.body.classList.contains('present-mode') || document.documentElement.classList.contains('present-mode');
    const targetPresent = new URLSearchParams(location.search).get('present') === '1';
    if (!currentPresent && !targetPresent) return;
    setSlidePreparing(true);

    const astroEvent = event as (Event & {
      newDocument?: Document;
      detail?: { newDocument?: Document };
    });
    const nextDocument = astroEvent.newDocument ?? astroEvent.detail?.newDocument;
    nextDocument?.documentElement.classList.add('present-mode', SLIDE_PREPARING_CLASS);
    nextDocument?.body?.classList.add('present-mode', SLIDE_PREPARING_CLASS);
  }
  document.addEventListener('astro:before-preparation', preparePresentNavigation);
  document.addEventListener('astro:before-swap', preparePresentNavigation);
  document.addEventListener('astro:page-load', initGlossaryInteractions);
  win.__akqGlossaryCleanup = () => {
    document.removeEventListener('keydown', onKey);
    document.removeEventListener('astro:before-preparation', preparePresentNavigation);
    document.removeEventListener('astro:before-swap', preparePresentNavigation);
    document.removeEventListener('astro:page-load', initGlossaryInteractions);
  };

  initGlossaryInteractions();

  // ── Mermaid (loaded async, won't block keyboard) ───────────────
  let mermaidRenderPromise: Promise<void> | null = null;

  async function renderMermaid() {
    if (mermaidRenderPromise) return mermaidRenderPromise;

    mermaidRenderPromise = renderMermaidNow().finally(() => {
      mermaidRenderPromise = null;
    });
    return mermaidRenderPromise;
  }

  async function renderMermaidNow() {
    try {
      const blocks = document.querySelectorAll(
        'pre[data-language="mermaid"], pre > code.language-mermaid'
      );
      const existingWraps = document.querySelectorAll('.mermaid-wrap');
      if (blocks.length === 0 && existingWraps.length === 0) return;
      if (blocks.length === 0) {
        applyMermaidSizing();
        return;
      }

      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        themeVariables: {
          background: '#0a0e27',
          primaryColor: '#0a0e27',
          primaryTextColor: '#e8f4ff',
          primaryBorderColor: '#00f0ff',
          lineColor: '#00f0ff',
          secondaryColor: '#1a0a2e',
          tertiaryColor: '#05060f',
        },
          securityLevel: 'loose',
      });
      blocks.forEach((el, i) => {
        const pre = el.tagName === 'PRE' ? (el as HTMLElement) : (el.parentElement as HTMLElement | null);
        if (!pre || pre.dataset.mermaidProcessed === '1') return;
        pre.dataset.mermaidProcessed = '1';
        const raw = pre.textContent || '';
        const wrap = document.createElement('div');
        wrap.className = 'mermaid-wrap';
        // Preserve slide-engine classes if pre was tagged
        if (pre.classList.contains('akq-slide-el')) wrap.classList.add('akq-slide-el');
        if (pre.classList.contains('akq-slide-hidden')) wrap.classList.add('akq-slide-hidden');
        if (pre.classList.contains('akq-slide-active')) wrap.classList.add('akq-slide-active');
        wrap.id = `mermaid-${Date.now()}-${i}`;
        wrap.textContent = raw;
        pre.replaceWith(wrap);
      });

      // Mermaid can't render inside display:none slides — temporarily
      // move hidden wraps offscreen, render, then restore.
      const allWraps = Array.from(document.querySelectorAll<HTMLElement>('.mermaid-wrap'));
      const restored: Array<{ el: HTMLElement; orig: string }> = [];
      const restoredHiddenAncestors = new Map<HTMLElement, { orig: string; hadHidden: boolean }>();
      allWraps.forEach((el) => {
        const cs = window.getComputedStyle(el);
        if (cs.display === 'none') {
          restored.push({ el, orig: el.getAttribute('style') || '' });
          el.setAttribute(
            'style',
            (el.getAttribute('style') || '') +
              ';display:block !important;position:absolute !important;left:-99999px !important;top:0 !important;width:1100px !important;'
          );
        }

        let parent = el.parentElement;
        while (parent && !parent.classList.contains('playbook-detail')) {
          if (parent.classList.contains('akq-slide-hidden') && !restoredHiddenAncestors.has(parent)) {
            restoredHiddenAncestors.set(parent, {
              orig: parent.getAttribute('style') || '',
              hadHidden: true,
            });
            parent.classList.remove('akq-slide-hidden');
            parent.setAttribute(
              'style',
              (parent.getAttribute('style') || '') +
                ';display:block !important;position:absolute !important;left:-99999px !important;top:0 !important;width:1100px !important;visibility:hidden !important;'
            );
          }
          parent = parent.parentElement;
        }
      });
      await new Promise((r) => setTimeout(r, 30));
      try { await mermaid.run({ querySelector: '.mermaid-wrap' }); } catch (e) { console.error('[mermaid.run]', e); }
      // Keep mermaid's intrinsic size so vertical diagrams stay readable; CSS handles scrolling.
      applyMermaidSizing();
      restored.forEach(({ el, orig }) => {
        if (orig) el.setAttribute('style', orig); else el.removeAttribute('style');
      });
      restoredHiddenAncestors.forEach(({ orig, hadHidden }, el) => {
        if (orig) el.setAttribute('style', orig); else el.removeAttribute('style');
        if (hadHidden) el.classList.add('akq-slide-hidden');
      });

    } catch (err) {
      console.error('[mermaid]', err);
    }
  }

  function applyMermaidSizing() {
    document.querySelectorAll<SVGSVGElement>('.mermaid-wrap svg').forEach((svg) => {
      svg.removeAttribute('width');
      svg.removeAttribute('height');
      svg.style.maxWidth = 'none';
      svg.style.height = 'auto';
    });
  }

