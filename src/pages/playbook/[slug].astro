  /* Per-category pixel-art backdrops for present mode.
     Shared positioning rule + per-category background-image overrides.
     Cover slide (body.slide-cover) uses a lighter overlay so the artwork breathes.
     NOTE: do NOT use background-attachment: fixed — the slide-in @keyframes
     uses filter: blur(...) which creates a containing block and intermittently
     breaks fixed backgrounds (per CSS spec). */
  body.present-mode .playbook-detail[data-category="introduction"],
  body.present-mode .playbook-detail[data-category="plan"],
  body.present-mode .playbook-detail[data-category="develop"],
  body.present-mode .playbook-detail[data-category="review"],
  body.present-mode .playbook-detail[data-category="secure"],
  body.present-mode .playbook-detail[data-category="operate"],
  body.present-mode .playbook-detail[data-category="administration"] {
    background-color: #05060f;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  /* INTRODUCTION → spaceport with category-planets */
  body.present-mode .playbook-detail[data-category="introduction"] {
    background-image:
      linear-gradient(180deg, rgba(5, 6, 15, 0.86) 0%, rgba(5, 6, 15, 0.90) 55%, rgba(5, 6, 15, 0.94) 100%),
      url('/slide-bg-introduction.webp');
  }
  body.present-mode.slide-cover .playbook-detail[data-category="introduction"] {
    background-image:
      linear-gradient(180deg, rgba(5, 6, 15, 0.55) 0%, rgba(5, 6, 15, 0.68) 55%, rgba(5, 6, 15, 0.82) 100%),
      url('/slide-bg-introduction.webp');
