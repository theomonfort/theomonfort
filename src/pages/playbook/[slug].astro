  body.present-mode .playbook-detail {
    max-width: none !important;
    width: 100vw !important;
    height: 100vh;
    max-height: 100vh;
    padding: 5rem 2.5rem 3rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: safe center;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  body.present-mode .playbook-detail > header {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  body.present-mode .playbook-detail > a:first-child,
  body.present-mode .playbook-detail > nav:not(.present-toc),
  body.present-mode .playbook-detail > aside:not(.akq-slide-active) { display: none !important; }
  body.present-mode .playbook-detail > aside.akq-slide-active { display: block !important; }
  body.present-mode .playbook-detail > aside.links-aside.akq-slide-active {
