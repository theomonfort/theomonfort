      url('/slide-bg-plan.webp');
  }
  body.present-mode.slide-cover .playbook-detail[data-category="plan"] {
    background-image:
      linear-gradient(180deg, rgba(5, 6, 15, 0.55) 0%, rgba(5, 6, 15, 0.68) 55%, rgba(5, 6, 15, 0.82) 100%),
