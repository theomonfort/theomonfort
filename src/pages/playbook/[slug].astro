    font-family: 'Press Start 2P', monospace;
    font-size: 0.9rem;
    border: 2px solid #05060f;
  }
  .prose-akq .pd-icon {
    font-size: 2.4rem;
    line-height: 1;
    margin-bottom: 0.3em;
  }
  .prose-akq .pd-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--pd-color);
    letter-spacing: 0.04em;
    margin-bottom: 0.2em;
  }
  .prose-akq .pd-sub {
    font-size: 0.95rem;
    opacity: 0.85;
    margin-bottom: 0.6em;
    line-height: 1.4;
  }
  .prose-akq .pd-cost {
    display: inline-block;
    font-family: 'Press Start 2P', monospace;
    font-size: 0.7rem;
    padding: 0.4em 0.7em;
