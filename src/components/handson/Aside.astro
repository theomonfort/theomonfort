---
interface Props {
  type?: 'positive' | 'negative';
}
const { type = 'positive' } = Astro.props;
const isNegative = type === 'negative';
const label = isNegative ? '⚠️ NOTE' : '💡 TIP';
---

<aside class={`handson-aside aside-${type}`} data-aside={type}>
  <span class="aside-marker font-pixel text-[10px]" aria-hidden="true">{label}</span>
  <div class="aside-body">
    <slot />
  </div>
</aside>
