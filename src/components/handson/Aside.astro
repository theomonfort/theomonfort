---
interface Props {
  type?: 'positive' | 'negative' | 'reference';
}
const { type = 'positive' } = Astro.props;
const marker = type === 'negative' ? '⚠️ NOTE' : type === 'reference' ? null : '💡 TIP';
---

<aside class={`handson-aside aside-${type}`} data-aside={type}>
  {marker && <span class="aside-marker font-pixel text-[10px]" aria-hidden="true">{marker}</span>}
  <div class="aside-body">
    <slot />
  </div>
</aside>
