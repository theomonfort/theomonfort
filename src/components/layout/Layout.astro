---
import '../../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import CRTOverlay from '../retro/CRTOverlay.tsx';
import BGMPlayer from '../interactive/BGMPlayer.tsx';
import KonamiListener from '../interactive/KonamiListener.tsx';
import XPHud from '../interactive/XPHud.tsx';
import BootSequence from '../interactive/BootSequence.tsx';
import Footer from './Footer.astro';
import Nav from './Nav.astro';
import { localizedPath, otherLocale, siteCopy, type Locale } from '../../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  hud?: boolean;
  locale?: Locale;
  currentPath?: string;
}
const {
  locale = 'ja',
  currentPath = '/',
  title,
  description,
  hud = true,
} = Astro.props;
const copy = siteCopy[locale];
const pageTitle = title ?? copy.siteTitle;
const pageDescription = description ?? copy.siteDescription;
const alternateLocale = otherLocale(locale);
const jaUrl = localizedPath('ja', currentPath);
const enUrl = localizedPath('en', currentPath);
---

<!doctype html>
<html lang={copy.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#0a0e27" />
    <meta property="og:locale" content={copy.localeCode} />
    <meta property="og:locale:alternate" content={siteCopy[alternateLocale].localeCode} />
    <link rel="alternate" hreflang="ja" href={jaUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={jaUrl} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=DotGothic16&family=VT323&family=Noto+Sans+JP:wght@400;700&family=IBM+Plex+Mono:wght@400;700&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href="/theomonfort/mascot.svg" />
    <ClientRouter />
  </head>
  <body class="bg-stars min-h-screen relative">
    <BootSequence client:load transition:persist locale={locale} copy={{ brandMiddle: copy.brandMiddle }} />
    <CRTOverlay client:load transition:persist />
    {hud && <XPHud client:load transition:persist />}
    <BGMPlayer client:load transition:persist />
    <KonamiListener client:load transition:persist secretPath={localizedPath(locale, '/secret')} />

    <!-- Page-transition wipe overlay (CRT scanline sweep) -->
    <div class="page-wipe" aria-hidden="true" transition:persist></div>

    <div class="relative z-10">
      <Nav locale={locale} currentPath={currentPath} />
      <main class="relative" transition:animate="none">
        <slot />
      </main>
      <Footer locale={locale} currentPath={currentPath} />
    </div>

    <script>
      // Retro page-transition: scanline wipe + SFX on every navigation.
      import('../../lib/sfx').then(({ play }) => {
        const win = window as Window & typeof globalThis & {
          __akqPageTransitionCleanup?: () => void;
        };

        win.__akqPageTransitionCleanup?.();

        const wipe = document.querySelector<HTMLElement>('.page-wipe');

        const runWipe = () => {
          if (wipe) {
            wipe.classList.remove('is-wiping');
            // force reflow so the animation restarts
            void wipe.offsetWidth;
            wipe.classList.add('is-wiping');
          }
          play('hover');
        };

        const resetScroll = () => {
          window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
        };

        const clearWipe = () => {
          setTimeout(() => wipe?.classList.remove('is-wiping'), 700);
        };

        document.addEventListener('astro:before-preparation', runWipe);
        document.addEventListener('astro:after-swap', resetScroll);
        document.addEventListener('astro:page-load', clearWipe);

        win.__akqPageTransitionCleanup = () => {
          document.removeEventListener('astro:before-preparation', runWipe);
          document.removeEventListener('astro:after-swap', resetScroll);
          document.removeEventListener('astro:page-load', clearWipe);
        };
      });
    </script>
  </body>
</html>
