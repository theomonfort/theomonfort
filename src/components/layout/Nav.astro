---
import { localizedPath, siteCopy, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
  currentPath?: string;
}
const { locale = 'ja', currentPath = '/' } = Astro.props;
const t = siteCopy[locale];
const items = [
  { path: '/', label: t.nav.hub, short: t.nav.hubShort },
  { path: '/playbook', label: t.nav.playbook, short: t.nav.playbookShort },
  { path: '/skills', label: t.nav.equipment, short: t.nav.equipmentShort },
  { path: '/philosophy', label: t.nav.philosophy, short: t.nav.philosophyShort },
  { path: '/links', label: t.nav.links, short: t.nav.linksShort },
];
---

<header class="sticky top-0 z-40 backdrop-blur bg-midnight/70 border-b-2 border-neon-magenta/40">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <a
      href={localizedPath(locale, '/')}
      class="group inline-flex items-center gap-2.5 text-neon-magenta hover:text-neon-cyan transition-colors leading-none"
      aria-label={t.brandAria}
    >
      <img
        src="/theomonfort/mascot.svg"
        alt=""
        class="w-6 h-6 md:w-7 md:h-7 shrink-0 pixelated drop-shadow-[0_0_4px_rgba(255,46,136,0.6)] group-hover:drop-shadow-[0_0_6px_rgba(0,240,255,0.7)] transition-[filter]"
        aria-hidden="true"
      />
      <span class="font-pixel text-[11px] md:text-[13px] tracking-[0.05em]">AI</span>
      <span class="font-pixel-jp text-base md:text-lg leading-none -mt-0.5">{t.brandMiddle}</span>
      <span class="font-pixel text-[11px] md:text-[13px] tracking-[0.1em]">QUEST</span>
    </a>
    <ul class="flex items-center gap-1 md:gap-2 flex-wrap text-[10px] md:text-xs font-pixel">
      {items.slice(1).map((item) => {
        const active = currentPath === item.path || currentPath.startsWith(item.path + '/');
        return (
          <li>
            <a
              href={localizedPath(locale, item.path)}
              class={`px-2 md:px-3 py-2 border-2 transition-colors ${
                active
                  ? 'border-neon-cyan text-neon-cyan shadow-neon-cyan'
                  : 'border-transparent text-phosphor/70 hover:text-neon-cyan hover:border-neon-cyan/40'
              }`}
            >
              <span class="hidden md:inline">{item.label}</span>
              <span class="md:hidden font-pixel-jp">{item.short}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
