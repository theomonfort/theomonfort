---
import { localizedPath, otherLocale, siteCopy, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
  currentPath?: string;
}
const { locale = 'ja', currentPath = '/' } = Astro.props;
const year = new Date().getFullYear();
const t = siteCopy[locale];
const targetLocale = otherLocale(locale);
---

<footer class="border-t-2 border-neon-magenta/30 mt-24 py-8 px-4 text-center font-pixel text-[10px] text-phosphor/60">
  <div class="max-w-3xl mx-auto space-y-3">
    <div class="flex items-center justify-center gap-3 text-crt-amber">
      <img src="/theomonfort/favicon.svg" alt="" class="w-6 h-6 pixelated opacity-90" aria-hidden="true" />
      <span>{t.footer.end}</span>
      <img src="/theomonfort/favicon.svg" alt="" class="w-6 h-6 pixelated opacity-90 -scale-x-100" aria-hidden="true" />
    </div>

    <div class="pt-2 font-pixel text-[10px] text-phosphor/70">
      <span class="text-phosphor/40">{t.footer.languageLabel}</span>
      <span aria-hidden="true"> · </span>
      <a href={localizedPath(targetLocale, currentPath)} class="text-neon-cyan hover:text-neon-magenta transition-colors">
        ▶ {t.footer.switchTo}
      </a>
    </div>

    <ul class="flex flex-col items-center justify-center gap-2 pt-2 font-pixel-jp text-sm">
      <li>
        <a href="https://github.com/theomonfort" target="_blank" rel="noopener noreferrer"
           class="retro-link inline-flex items-center gap-1.5">
          <span aria-hidden="true">▶</span> GitHub profile: @theomonfort
        </a>
      </li>
      <li>
        <a href="https://github.com/theomonfort/theomonfort" target="_blank" rel="noopener noreferrer"
           class="retro-link inline-flex items-center gap-1.5">
          <span aria-hidden="true">▶</span> {t.footer.repository}
        </a>
      </li>
      <li>
        <a href="https://forms.office.com/Pages/ResponsePage.aspx?id=v4j5cvGGr0GRqy180BHbRxfrxixxnh1AkgHlZ0RLul1UQ0dZSUM1V1Y0Vks2RUNEVElHUU9ZVjMySC4u" target="_blank" rel="noopener noreferrer"
           class="retro-link inline-flex items-center gap-1.5">
          <span aria-hidden="true">▶</span> {t.footer.feedback}
        </a>
      </li>
    </ul>

    <p class="font-mono text-[10px] text-phosphor/40">© {year} — AI KUDŌ KAIHATSU QUEST · {t.footer.konami}</p>
    <p class="font-mono text-[10px] text-phosphor/30">
      {t.footer.attribution}
      <a href="https://www.flaticon.com/" target="_blank" rel="noopener noreferrer" class="text-neon-cyan/70 hover:text-neon-magenta transition-colors underline decoration-dotted underline-offset-2">{t.footer.attributionSource}</a>
    </p>
  </div>
</footer>
