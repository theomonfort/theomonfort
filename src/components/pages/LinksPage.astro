---
import Layout from '../layout/Layout.astro';
import { categories, localizedCategory } from '../../lib/playbook-categories';
import { localizedPath, siteCopy, type Locale } from '../../lib/i18n';
import { getPlaybookEntries, playbookEntryTitle } from '../../lib/playbook';

interface Props {
  locale?: Locale;
}
const { locale = 'ja' } = Astro.props;
const t = siteCopy[locale];

const allEntries = (await getPlaybookEntries(locale))
  .filter((e) => e.entry.data.links.length > 0)
  .sort((a, b) => a.entry.data.order - b.entry.data.order);

const colorMap: Record<string, { hex: string; tw: string; bg: string; chipBg: string }> = {
  magenta: { hex: '#ff2e88', tw: 'text-neon-magenta', bg: 'rgba(255,46,136,0.10)', chipBg: 'rgba(255,46,136,0.20)' },
  cyan:    { hex: '#00f0ff', tw: 'text-neon-cyan',    bg: 'rgba(0,240,255,0.10)', chipBg: 'rgba(0,240,255,0.18)' },
  amber:   { hex: '#ffb000', tw: 'text-crt-amber',    bg: 'rgba(255,176,0,0.10)', chipBg: 'rgba(255,176,0,0.20)' },
  green:   { hex: '#9bbc0f', tw: 'text-gb-green',     bg: 'rgba(155,188,15,0.10)', chipBg: 'rgba(155,188,15,0.22)' },
};

type CatId = (typeof categories)[number]['id'];
const grouped: Record<CatId, typeof allEntries> = {
  introduction: [], plan: [], develop: [], review: [], secure: [], operate: [],
};
for (const e of allEntries) grouped[e.entry.data.category as CatId].push(e);

const totalLinks = allEntries.reduce((n, e) => n + e.entry.data.links.length, 0);

function groupLinks(links: { label: string; url: string; group?: string }[]) {
  const buckets: { name: string; items: typeof links }[] = [];
  for (const l of links) {
    const g = l.group ?? '';
    let b = buckets.find((x) => x.name === g);
    if (!b) { b = { name: g, items: [] }; buckets.push(b); }
    b.items.push(l);
  }
  return buckets;
}

function host(url: string) {
  try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return ''; }
}
---

<Layout locale={locale} currentPath="/links" title={t.links.title}>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-6">
      <p class="font-pixel text-[10px] text-crt-amber tracking-[0.3em] mb-2">{t.links.chapter}</p>
      <h1 class="font-pixel text-2xl md:text-4xl text-neon-magenta mb-3">{t.links.heading}</h1>
      <p class="font-pixel-jp text-lg text-neon-cyan">{t.links.subtitle}</p>
      <p class="font-body text-sm text-phosphor/80 mt-3">
        {t.links.intro}
        <span id="link-counter" class="text-crt-amber">{totalLinks}</span>
        <span class="text-phosphor/60">/ {totalLinks} {t.links.showing}</span>
      </p>
    </header>

    <div class="link-controls sticky top-0 z-30 -mx-4 px-4 py-4 mb-6 bg-shadow-ink/95 backdrop-blur border-b-2 border-phosphor/15">
      <div class="relative mb-3">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 font-pixel text-[10px] text-neon-cyan pointer-events-none">▶</span>
        <input
          id="link-search"
          type="search"
          placeholder={t.links.placeholder}
          class="w-full pl-9 pr-10 py-2.5 bg-shadow-ink border-2 border-phosphor/25 focus:border-neon-cyan focus:outline-none font-pixel-jp text-sm text-phosphor placeholder:text-phosphor/40"
          autocomplete="off"
        />
        <button
          id="link-clear"
          type="button"
          class="absolute right-2 top-1/2 -translate-y-1/2 font-pixel text-[10px] text-phosphor/40 hover:text-neon-magenta hidden"
          aria-label="Clear search"
        >
          ✕ CLEAR
        </button>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <span class="font-pixel text-[9px] text-phosphor/50 mr-1">{t.links.filter}</span>
        {categories.map((rawCat) => {
          const cat = localizedCategory(rawCat, locale);
          const c = colorMap[rawCat.color];
          const count = grouped[rawCat.id].reduce((n, e) => n + e.entry.data.links.length, 0);
          if (count === 0) return null;
          return (
            <button
              type="button"
              class={`cat-chip font-pixel text-[9px] px-2 py-1 border-2 ${c.tw} transition-all`}
              data-category={rawCat.id}
              style={`border-color:${c.hex}`}
              aria-pressed="true"
            >
              <span class="mr-1">{rawCat.icon}</span>{cat.label.toUpperCase()}
              <span class="opacity-60 ml-1">{count}</span>
            </button>
          );
        })}
        <button
          id="cat-all"
          type="button"
          class="font-pixel text-[9px] px-2 py-1 border-2 border-phosphor/30 text-phosphor/70 hover:border-neon-magenta hover:text-neon-magenta ml-auto"
        >
          {t.links.all}
        </button>
        <button
          id="cat-none"
          type="button"
          class="font-pixel text-[9px] px-2 py-1 border-2 border-phosphor/30 text-phosphor/70 hover:border-neon-magenta hover:text-neon-magenta"
        >
          {t.links.none}
        </button>
      </div>
    </div>

    <div id="link-list">
      {categories.map((rawCat) => {
        const entries = grouped[rawCat.id];
        if (entries.length === 0) return null;
        const cat = localizedCategory(rawCat, locale);
        const c = colorMap[rawCat.color];
        return (
          <section class="cat-section mb-10" data-category={rawCat.id}>
            <header
              class="flex items-baseline gap-3 mb-4 pb-2 border-b-2"
              style={`border-color:${c.hex}`}
            >
              <span class="text-2xl leading-none">{rawCat.icon}</span>
              <h2 class={`font-pixel text-sm md:text-base tracking-[0.25em] ${c.tw}`}>
                {cat.label.toUpperCase()}
              </h2>
            </header>

            <div class="space-y-5">
              {entries.map((item) => {
                const e = item.entry;
                const buckets = groupLinks(e.data.links);
                const cardTitle = e.data.titleEn || playbookEntryTitle(item);
                const cardSubtitle = locale === 'ja' && e.data.titleEn && e.data.title !== e.data.titleEn
                  ? e.data.title
                  : undefined;
                return (
                  <article class="entry-block pl-3 border-l-2" data-entry={item.slug} style={`border-color:${c.hex}40`}>
                    <header class="flex items-baseline gap-2 mb-2 flex-wrap">
                      <span class="text-base leading-none">{e.data.icon.startsWith('/') ? '▶' : e.data.icon}</span>
                      <h3 class="font-pixel text-sm text-phosphor">{cardTitle}</h3>
                      {cardSubtitle && <span class="font-pixel-jp text-xs text-phosphor/55">{cardSubtitle}</span>}
                      <a
                        href={localizedPath(locale, `/playbook/${item.slug}`)}
                        class={`font-pixel text-[8px] ${c.tw} opacity-70 hover:opacity-100`}
                      >
                        {t.links.openEntry}
                      </a>
                    </header>

                    {item.isFallback && <p class="font-pixel text-[9px] text-crt-amber mb-2">{t.common.translationPending}</p>}

                    {buckets.map((bucket) => (
                      <div class="bucket-block mb-3" data-bucket={bucket.name || '_default'}>
                        {bucket.name && (
                          <h4 class="font-pixel-jp text-xs text-phosphor/55 mb-1.5 ml-1">{bucket.name}</h4>
                        )}
                        <ul class="space-y-1">
                          {bucket.items.map((it) => {
                            const search = `${it.label} ${it.url} ${cardTitle} ${cardSubtitle ?? ''} ${bucket.name ?? ''} ${cat.label}`.toLowerCase();
                            return (
                              <li
                                class="link-row"
                                data-search={search}
                                data-category={rawCat.id}
                              >
                                <a
                                  href={it.url}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="link-row-inner flex items-baseline gap-2 px-2 py-1.5 border-l-2 border-transparent hover:border-[color:var(--accent)] hover:bg-[color:var(--accent-bg)] transition-colors"
                                  style={`--accent:${c.hex}; --accent-bg:${c.bg};`}
                                >
                                  <span class={`font-pixel text-[9px] ${c.tw} shrink-0`}>▸</span>
                                  <span class="font-pixel-jp text-sm text-phosphor flex-1 break-words leading-snug link-label">{it.label}</span>
                                  <span class="font-mono text-[10px] text-phosphor/40 shrink-0 hidden sm:inline">{host(it.url)}</span>
                                  <span class="font-mono text-[10px] text-phosphor/40 shrink-0">↗</span>
                                </a>
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    ))}
                  </article>
                );
              })}
            </div>
          </section>
        );
      })}

      <div id="no-results" class="hidden text-center py-12">
        <p class="font-pixel text-sm text-neon-magenta mb-2">{t.links.noMatchTitle}</p>
        <p class="font-pixel-jp text-sm text-phosphor/60">{t.links.noMatchBody}</p>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a href={localizedPath(locale, '/')} class="font-pixel text-[10px] text-phosphor/60 hover:text-neon-magenta">{t.common.backHome}</a>
    </div>
  </section>
</Layout>

<style is:global>
  .cat-chip {
    box-shadow: 2px 2px 0 #05060f;
  }
  .cat-chip[aria-pressed='false'] {
    opacity: 0.30;
    filter: grayscale(0.7);
  }
  .cat-chip:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 #05060f; }

  .link-row .link-label mark {
    background: transparent;
    color: #ffb000;
    font-weight: 700;
    text-shadow: 0 0 6px rgba(255, 176, 0, 0.6);
  }

  #link-search:focus { box-shadow: 0 0 0 2px rgba(0, 240, 255, 0.25); }

  .link-row.is-hidden,
  .bucket-block.is-hidden,
  .entry-block.is-hidden,
  .cat-section.is-hidden { display: none !important; }
</style>

<script is:inline>
  (() => {
    const search = document.getElementById('link-search');
    const clearBtn = document.getElementById('link-clear');
    const counter = document.getElementById('link-counter');
    const noResults = document.getElementById('no-results');
    const allBtn = document.getElementById('cat-all');
    const noneBtn = document.getElementById('cat-none');
    const chips = Array.from(document.querySelectorAll('.cat-chip'));
    const rows = Array.from(document.querySelectorAll('.link-row'));
    const buckets = Array.from(document.querySelectorAll('.bucket-block'));
    const entries = Array.from(document.querySelectorAll('.entry-block'));
    const sections = Array.from(document.querySelectorAll('.cat-section'));

    const activeCats = new Set(chips.map((c) => c.dataset.category));

    const escapeHtml = (s) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const escapeRegex = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

    const apply = () => {
      const q = (search.value || '').trim().toLowerCase();
      const tokens = q.split(/\s+/).filter(Boolean);
      const re = q ? new RegExp(escapeRegex(q), 'ig') : null;
      let visible = 0;

      rows.forEach((row) => {
        const inCat = activeCats.has(row.dataset.category);
        const text = row.dataset.search;
        const matches = tokens.length === 0 || tokens.every((token) => text.includes(token));
        const show = inCat && matches;
        row.classList.toggle('is-hidden', !show);
        if (show) visible += 1;

        const label = row.querySelector('.link-label');
        if (label) {
          const original = label.textContent || '';
          if (re && show) {
            label.innerHTML = escapeHtml(original).replace(re, (m) => `<mark>${escapeHtml(m)}</mark>`);
          } else {
            label.textContent = original;
          }
        }
      });

      buckets.forEach((bucket) => {
        const anyVisible = bucket.querySelectorAll('.link-row:not(.is-hidden)').length > 0;
        bucket.classList.toggle('is-hidden', !anyVisible);
      });
      entries.forEach((entry) => {
        const anyVisible = entry.querySelectorAll('.link-row:not(.is-hidden)').length > 0;
        entry.classList.toggle('is-hidden', !anyVisible);
      });
      sections.forEach((section) => {
        const anyVisible = section.querySelectorAll('.link-row:not(.is-hidden)').length > 0;
        section.classList.toggle('is-hidden', !anyVisible);
      });

      counter.textContent = String(visible);
      noResults.classList.toggle('hidden', visible !== 0);
      clearBtn.classList.toggle('hidden', q === '' && activeCats.size === chips.length);
    };

    search.addEventListener('input', apply);
    clearBtn.addEventListener('click', () => {
      search.value = '';
      chips.forEach((chip) => {
        chip.setAttribute('aria-pressed', 'true');
        activeCats.add(chip.dataset.category);
      });
      apply();
      search.focus();
    });
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const id = chip.dataset.category;
        if (activeCats.has(id)) {
          activeCats.delete(id);
          chip.setAttribute('aria-pressed', 'false');
        } else {
          activeCats.add(id);
          chip.setAttribute('aria-pressed', 'true');
        }
        apply();
      });
    });
    allBtn.addEventListener('click', () => {
      chips.forEach((chip) => {
        chip.setAttribute('aria-pressed', 'true');
        activeCats.add(chip.dataset.category);
      });
      apply();
    });
    noneBtn.addEventListener('click', () => {
      chips.forEach((chip) => chip.setAttribute('aria-pressed', 'false'));
      activeCats.clear();
      apply();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== search) {
        event.preventDefault();
        search.focus();
      }
      if (event.key === 'Escape' && document.activeElement === search) {
        search.value = '';
        apply();
      }
    });
  })();
</script>
