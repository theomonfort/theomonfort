---
import Layout from '../layout/Layout.astro';
import { localizedPath, siteCopy, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'ja' } = Astro.props;
const t = siteCopy[locale];
---

<Layout locale={locale} currentPath="/secret" title={t.secret.title} hud={false}>
  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <div class="animate-flicker">
      <p class="font-pixel text-[10px] text-crt-amber mb-4 tracking-[0.4em]">{t.secret.area}</p>
      <h1 class="font-pixel text-3xl md:text-5xl text-neon-magenta mb-6 drop-shadow-[0_0_12px_rgba(255,46,136,0.7)]">
        {t.secret.heading}
      </h1>
      <p class="font-pixel-jp text-2xl text-neon-cyan mb-10">{t.secret.found}</p>
    </div>

    <div class="bg-shadow-ink/90 border-4 border-crt-amber p-8 shadow-neon-amber">
      <p class="font-body text-base text-phosphor/95 leading-loose mb-6">
        {t.secret.intro}
      </p>
      <blockquote class="font-pixel-jp text-xl md:text-2xl text-crt-amber leading-loose">
        {t.secret.quote.split('\n').map((part, i) => <>{i > 0 && <br />}{part}</>)}
      </blockquote>
      <p class="font-body text-sm text-phosphor/70 mt-6 leading-relaxed">
        {t.secret.body.split('\n').map((part, i) => <>{i > 0 && <br />}{part}</>)}
      </p>
    </div>

    <div class="mt-10 space-y-3 font-pixel text-[10px]">
      <p class="text-gb-green">{t.secret.stat}</p>
      <a href={localizedPath(locale, '/')} class="inline-block px-4 py-3 border-2 border-neon-magenta text-neon-magenta hover:bg-neon-magenta hover:text-shadow-ink transition-colors">
        {t.common.backHome}
      </a>
    </div>
  </section>
</Layout>
